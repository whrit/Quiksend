# ── Core (required in Phase 0) ────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
# Matches docker-compose.yml credentials:
DATABASE_URL=postgres://quiksend:quiksend@localhost:5432/quiksend

# ── Auth (Phase 1) ────────────────────────────────────────────
# Required to run the web app. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Optional social login (leave blank to hide those buttons):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=

# ── Forward-looking (optional until later phases) ─────────────
# Integrations (Phase 3) — Nango Cloud (chosen over self-host for MVP).
# NANGO_SECRET_KEY=
# NANGO_WEBHOOK_SECRET=
# NANGO_PUBLIC_URL=http://localhost:3000

# AI (Phase 8) — either or both may be set; provider is per-workspace in settings.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AI_DEFAULT_PROVIDER=anthropic

# Local mail testing (Mailpit, from docker-compose.yml)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# 32-byte base64 key for encrypting SMTP mailbox credentials at rest.
# Generate with: openssl rand -base64 32
# MAILBOX_ENCRYPTION_KEY=

# Public API + outbound webhooks (Phase 10)
# Per-endpoint signing secrets are generated automatically when a webhook endpoint is created.
# UNSUBSCRIBE_TOKEN_SECRET signs unsubscribe links embedded in outbound messages.
UNSUBSCRIBE_TOKEN_SECRET=dev-unsubscribe-token-secret

# Observability (optional). Sentry for errors, PostHog for product analytics.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
# POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
