# ── Core (required in Phase 0) ────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
# Matches docker-compose.yml credentials:
DATABASE_URL=postgres://quiksend:quiksend@localhost:5432/quiksend

# ── Auth (Phase 1) ────────────────────────────────────────────
# Required to run the web app. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# The public URL the browser hits — MUST match the dev-server port below.
# If 3000 is taken on your host, set WEB_PORT=<free port> and update this
# to match (e.g. http://localhost:3005).
BETTER_AUTH_URL=http://localhost:3000
# Optional — Vite dev-server port. Defaults to 3000; strict-fails on collision
# rather than silently drifting so Better Auth callbacks / Nango webhook tunnels
# never end up pointing at the wrong service.
# WEB_PORT=3000
# Optional social login (leave blank to hide those buttons):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=

# ── Forward-looking (optional until later phases) ─────────────
# Integrations (Phase 3) — Nango Cloud (chosen over self-host for MVP).
# NANGO_SECRET_KEY=
# NANGO_WEBHOOK_SECRET=
# Public URL Nango redirects/callbacks land on. For local dev this is your
# ngrok tunnel to WEB_PORT (e.g. https://<subdomain>.ngrok-free.dev); in prod
# it's your own domain. Keep the port here in sync with WEB_PORT if you tunnel
# a non-default port.
# NANGO_PUBLIC_URL=http://localhost:3000

# AI (Phase 8) — either or both may be set; provider is per-workspace in settings.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AI_DEFAULT_PROVIDER=anthropic

# AI research web search providers — set one to enable real web search; empty falls back to fake fixtures.
# BRAVE_API_KEY=
# EXA_API_KEY=
# TAVILY_API_KEY=

# Local mail testing (Mailpit, from docker-compose.yml)
# SMTP_HOST=localhost
# 32-byte base64 key for encrypting SMTP mailbox credentials at rest.
# Generate with: openssl rand -base64 32
# MAILBOX_ENCRYPTION_KEY=

# ── Enterprise deliverability (Phase 11) ──────────────────────
# Daily send cap per (mailbox, SEG destination) tuple. Consumer ESPs already throttle;
# this is the extra hard cap applied when routing to Proofpoint/Mimecast/Barracuda/Cisco.
# SEG_DAILY_CAP_PER_MAILBOX=50

# Hostname used to strip tracking pixels in the SEG content sanitizer.
# Defaults to the hostname of BETTER_AUTH_URL when unset.
# TRACKING_PIXEL_DOMAIN=track.example.com

# 32-byte base64 key for encrypting provider-managed seed inbox IMAP credentials.
# Deployed only on Quiksend Systems infra to unlock Deliverability Pro's shared seed pool.
# Self-hosters can leave this UNSET — user-provided seed inboxes still work.
# Generate (Quiksend Systems only): openssl rand -base64 32
# SYSTEM_SEED_ENCRYPTION_KEY=

# Public API + outbound webhooks (Phase 10)
# Per-endpoint signing secrets are generated automatically when a webhook endpoint is created.
# UNSUBSCRIBE_TOKEN_SECRET signs unsubscribe links embedded in outbound messages.
UNSUBSCRIBE_TOKEN_SECRET=dev-unsubscribe-token-secret

# Observability (optional). Sentry for errors, PostHog for product analytics.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
# POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
