# ── Core (required in Phase 0) ────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
# Matches docker-compose.yml credentials:
DATABASE_URL=postgres://relay:relay@localhost:5432/relay

# ── Forward-looking (optional until later phases) ─────────────
