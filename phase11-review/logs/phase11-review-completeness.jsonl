stems only): openssl rand -base64 32\n# SYSTEM_SEED_ENCRYPTION_KEY=\n\n# Public API + outbound webhooks (Phase 10)\n# Per-endpoint signing secrets are generated automatically when a webhook endpoint is created.\n# UNSUBSCRIBE_TOKEN_SECRET signs unsubscribe links embedded in outbound messages.\nUNSUBSCRIBE_TOKEN_SECRET=dev-unsubscribe-token-secret\n\n# Observability (optional). Sentry for errors, PostHog for product analytics.","isEmpty":false,"exceededLimit":false,"totalLines":56,"fileSize":2491,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase11-review-completeness/.env.example","readRange":{"startLine":1,"endLine":50},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_3ea2d1ce-48a0-4943-84e1-d8cae5b0254","startedAtMs":"1783047839807","completedAtMs":"1783047843181"},"model_call_id":"be50de82-8188-4ec9-a623-56bd01639930-14-rinf","session_id":"2793f482-d070-4fe8-ae71-bcf9eb944fd7","timestamp_ms":1783047843223}
