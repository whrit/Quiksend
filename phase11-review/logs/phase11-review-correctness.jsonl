  condition.recipientGatewayNotIn.includes(ctx.recipientGateway)\n  ) {\n    return { proceed: false, skipReason: \"recipient_gateway_in_deny_list\" };\n  }\n\n  return { proceed: true };\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":67,"fileSize":1789,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase11-review-correctness/packages/core/src/state-machine/entry-conditions.ts","readRange":{"startLine":1,"endLine":67},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_bb2f8ab9-42b5-4279-984d-91d3389ed03","startedAtMs":"1783047681276","completedAtMs":"1783047694462"},"model_call_id":"3d67ff5e-c2d7-4141-a2a5-f5692c0d200e-4-us4g","session_id":"ea6a87f4-c096-4a35-b107-f6ccf68e1181","timestamp_ms":1783047694487}
