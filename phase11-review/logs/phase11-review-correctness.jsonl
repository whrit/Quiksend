ow new Error(\"Failed to advance enrollment step\");\n  return { ...ctx, enrollment: updated };\n}\n\nasync function captureAnchor(\n  tx: DbTx,\n  ctx: EnrollmentContext,\n  messageId: string,\n  threadId: string,\n): Promise<EnrollmentContext> {\n  const [updated] = await tx\n    .update(tables.enrollment)\n    .set({\n      anchorMessageId: messageId,\n      anchorThreadId: threadId,\n    })\n    .where(\n      and(\n        eq(tables.enrollment.id, ctx.enrollmentId),\n        eq(tables.enrollment.organizationId, ctx.organizationId),\n      ),\n    )\n    .returning();\n  if (!updated) throw new Error(\"Failed to capture anchor\");","isEmpty":false,"exceededLimit":false,"totalLines":577,"fileSize":16858,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase11-review-correctness/apps/worker/src/sequence/effects.ts","readRange":{"startLine":115,"endLine":194},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_ba9c952d-be08-48e4-ab4a-063c081c8bf","startedAtMs":"1783047868038","completedAtMs":"1783047870873"},"model_call_id":"3d67ff5e-c2d7-4141-a2a5-f5692c0d200e-16-6ijt","session_id":"ea6a87f4-c096-4a35-b107-f6ccf68e1181","timestamp_ms":1783047870890}
