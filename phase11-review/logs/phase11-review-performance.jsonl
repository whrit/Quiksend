     .where(and(...conditions))\n      .orderBy(order(sortColumn(data.sortField)), order(tables.prospect.id))\n      .limit(data.limit + 1);\n\n    const hasMore = rows.length > data.limit;\n    const page = hasMore ? rows.slice(0, data.limit) : rows;","isEmpty":false,"exceededLimit":false,"totalLines":1190,"fileSize":36171,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase11-review-performance/apps/web/src/lib/prospects.functions.ts","readRange":{"startLine":265,"endLine":314},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_0ea4cdf9-e23a-4932-b8a0-5b584ec3ed2","startedAtMs":"1783047905014","completedAtMs":"1783047908527"},"model_call_id":"170c7adf-35c5-4e99-a59d-e5b6bcb57ac0-10-v87h","session_id":"e15688e6-0a82-46f0-8a12-c73f1e36a7d0","timestamp_ms":1783047908542}
