t.gateway,\n        mxRecords: result.mxRecords,\n        evidence: result.evidence,\n        confidence: result.confidence,\n        classifiedAt: new Date(),\n        ttlUntil: ttlForConfidence(result.confidence, isFailure),\n      },\n    });\n}\n\nasync function applyClassificationToProspects(\n  domain: string,\n  gateway: EmailGateway,\n  evidence: Awaited<ReturnType<typeof detectEmailGateway>>[\"evidence\"],\n  organizationId?: string,\n): Promise<number> {\n  const conditions = [\n    sql`lower(split_part(${tables.prospect.email}, '@', 2)) = ${domain}`,\n    isNull(tables.prospect.deletedAt),\n  ];\n  if (organizationId) {\n    conditions.push(eq(tables.prospect.organizationId, organizationId));\n  }\n\n  const updated = await db\n    .update(tables.prospect)\n    .set({\n      emailGateway: gateway,\n      gatewayClassifiedAt: new Date(),\n      gatewayEvidence: evidence,\n    })\n    .where(and(...conditions))\n    .returning({ id: tables.prospect.id });\n\n  return updated.length;","isEmpty":false,"exceededLimit":false,"totalLines":235,"fileSize":7654,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase11-review-testing/apps/worker/src/handlers/gateway-detect.ts","readRange":{"startLine":1,"endLine":80},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_7c4b0b34-88e9-4bd7-8232-d9d97204167","startedAtMs":"1783047762843","completedAtMs":"1783047770410"},"model_call_id":"eb4a58e4-4e70-4763-9d52-7228ea2fcadd-6-vcv8","session_id":"dfb698a2-1290-4443-a1a8-fdd66a26b9d4","timestamp_ms":1783047770434}
