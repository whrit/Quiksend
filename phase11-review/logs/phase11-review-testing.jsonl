referPlainText: true,\n      },\n    );\n    expect(result.html).toBe(\"\");\n    expect(result.text).toBe(\"Hi\");\n  });\n\n  it(\"sanitizes multipart content while remaining usable\", () => {\n    const html =\n      '<p>Hello</p><img src=\"https://track.local/pixel\" /><img src=\"https://other.com/x.png\" />';\n    const result = sanitizeForSeg(\n      { html, text: \"Hello\" },\n      {\n        stripTrackingPixel: true,\n        stripExternalImages: true,\n        preferPlainText: true,\n        trackingDomain: \"track.local\",\n      },\n    );\n    expect(result.html).toBe(\"\");\n    expect(result.text).toBe(\"Hello\");\n  });\n});\n","isEmpty":false,"exceededLimit":false,"totalLines":76,"fileSize":2232,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase11-review-testing/packages/mail/src/content-sanitizer.test.ts","readRange":{"startLine":1,"endLine":76},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_575b3eac-2c87-404a-b58f-ccd4a2f66d3","startedAtMs":"1783047709986","completedAtMs":"1783047717579"},"model_call_id":"eb4a58e4-4e70-4763-9d52-7228ea2fcadd-2-3fnh","session_id":"dfb698a2-1290-4443-a1a8-fdd66a26b9d4","timestamp_ms":1783047717601}
