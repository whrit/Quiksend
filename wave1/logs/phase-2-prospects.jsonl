({ many }) => ({\n  members: many(member),\n  invitations: many(invitation),\n}));\n\nexport const memberRelations = relations(member, ({ one }) => ({\n  organization: one(organization, {\n    fields: [member.organizationId],\n    references: [organization.id],\n  }),\n  user: one(user, {\n    fields: [member.userId],\n    references: [user.id],\n  }),\n}));\n\nexport const invitationRelations = relations(invitation, ({ one }) => ({\n  organization: one(organization, {\n    fields: [invitation.organizationId],\n    references: [organization.id],\n  }),\n  user: one(user, {\n    fields: [invitation.inviterId],\n    references: [user.id],\n  }),\n}));\n","isEmpty":false,"exceededLimit":false,"totalLines":219,"fileSize":6568,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-2-prospects/packages/db/src/schema/auth.ts","readRange":{"startLine":80,"endLine":219},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_760987f3-4599-4f03-98a0-e3774b7c600","startedAtMs":"1782957276654","completedAtMs":"1782957278495"},"model_call_id":"5977d0c1-3ad5-42be-85f2-1e8828435224-7-du3e","session_id":"6573c6ff-6012-4c40-8cb2-1911b390dd96","timestamp_ms":1782957278464}
{"type":"tool_call","subtype":"completed","call_id":"tool_d551d29d-90fc-4388-afe6-3ebefce951b","tool_call":{"mcpToolCall":{"args":{"name":"context7-query-docs","args":{"libraryId":"/websites/orm_drizzle_team","query":"pgEnum uniqueIndex where isNotNull partial index sql drizzle-orm pg-core"},"toolCallId":"tool_d551d29d-90fc-4388-afe6-3ebefce951b","providerIdentifier":"context7","toolName":"query-docs","smartModeApprovalOnly":false,"skipApproval":false},"result":{"success":{"content":[{"text":{"text":"### Define Users Table with Case-Insensitive Unique Email Index (PostgreSQL)\n\nSource: https://orm.drizzle.team/docs/guides/unique-case-insensitive-email\n\nDefines the 'users' table schema in Drizzle ORM for PostgreSQL, including a unique index on the lowercased 'email' column to enforce case-insensitive uniqueness. Requires 'drizzle-orm/pg-core' and 'drizzle-orm'.\n\n```typescript\nimport { SQL, sql } from 'drizzle-orm';\nimport { AnyPgColumn, pgTable, serial, text, uniqueIndex } from 'drizzle-orm/pg-core';\n\nexport const users = pgTable(\n  'users',\n  {\n    id: serial('id').primaryKey(),\n    name: text('name').notNull(),\n    email: text('email').notNull(),\n  },\n  (table) => [\n    // uniqueIndex('emailUniqueIndex').on(sql`lower(${table.email})`),\n    uniqueIndex('emailUniqueIndex').on(lower(table.email)),\n  ],\n);\n\n// custom lower function\nexport function lower(email: AnyPgColumn): SQL {\n  return sql`lower(${email})`;\n}\n```\n\n--------------------------------\n\n### PostgreSQL Migration SQL for Unique Email Index\n\nSource: https://orm.drizzle.team/docs/guides/unique-case-insensitive-email\n\nGenerates the SQL statement to create a unique index on the 'email' column using the lowercased value in PostgreSQL. This is typically generated by Drizzle's migration tools.\n\n```sql\nCREATE TABLE IF NOT EXISTS \"users\" (\n  \"id\" serial PRIMARY KEY NOT NULL,\n  \"name\" text NOT NULL,\n  \"email\" text NOT NULL\n);\n--> statement-breakpoint\nCREATE UNIQUE INDEX IF NOT EXISTS \"emailUniqueIndex\" ON \"users\" USING btree (lower(\"email\"));\n```\n\n--------------------------------\n\n### SQLite CREATE TABLE and UNIQUE INDEX Statements\n\nSource: https://orm.drizzle.team/docs/guides/unique-case-insensitive-email\n\nSQL statements to create a SQLite table and a unique index on the lowercased email column, ensuring case-insensitive uniqueness.\n\n```sql\nCREATE TABLE `users` (\n    `id` integer PRIMARY KEY NOT NULL,\n    `name` text NOT NULL,\n    `email` text NOT NULL\n);\n--> statement-breakpoint\nCREATE UNIQUE INDEX `emailUniqueIndex` ON `users` (lower(`email`));\n```\n\n--------------------------------\n\n### MySQL CREATE TABLE Statement for Unique Email Index\n\nSource: https://orm.drizzle.team/docs/guides/unique-case-insensitive-email\n\nThe SQL statement to create a MySQL table with a unique index on the lowercased email column. This ensures email uniqueness irrespective of case.\n\n```sql\nCREATE TABLE `users` (\n    `id` serial AUTO_INCREMENT NOT NULL,\n    `name` varchar(255) NOT NULL,\n    `email` varchar(255) NOT NULL,\n    CONSTRAINT `users_id` PRIMARY KEY(`id`),\n    CONSTRAINT `emailUniqueIndex` UNIQUE((lower(`email`)))\n);\n```\n\n### latest-releases/drizzle-orm-v0310.md\n\nSource: https://orm.drizzle.team/docs/latest-releases/drizzle-orm-v0310\n\nThe PostgreSQL indexes API has been updated in Drizzle ORM v0.31.0 to align with PostgreSQL documentation. The new API allows for SQL expressions within `.on` and clarifies the usage of `.using` and `.on`. It also correctly associates `.asc()`, `.desc()`, `.nullsFirst()`, and `.nullsLast()` with individual columns or expressions, not the index itself. The `where` clause and `fillfactor` option are also supported."}}],"isError":false}}},"hookAdditionalContexts":[],"toolCallId":"tool_d551d29d-90fc-4388-afe6-3ebefce951b","startedAtMs":"1782957274731","completedAtMs":"1782957280213"},"model_call_id":"5977d0c1-3ad5-42be-85f2-1e8828435224-7-du3e","session_id":"6573c6ff-