{"type":"tool_call","subtype":"started","call_id":"tool_0a490da7-ba9f-4c1d-908b-e73c62daa44","tool_call":{"editToolCall":{"args":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-2-prospects/apps/web/src/routes/_protected/prospects/index.tsx","streamContent":"function SelectAllHeader({ table }: { table: ReturnType<typeof useReactTable<ProspectRow>> }) {\n  return (\n    <Checkbox\n      checked={\n        table.getIsAllPageRowsSelected() ||\n        (table.getIsSomePageRowsSelected() && \"indeterminate\")\n      }\n      onCheckedChange={(v) => table.toggleAllPageRowsSelected(!!v)}\n      aria-label=\"Select all\"\n    />\n  );\n}\n\nfunction SelectRowCell({ row }: { row: { getIsSelected: () => boolean; toggleSelected: (v: boolean) => void } }) {\n  return (\n    <Checkbox\n      checked={row.getIsSelected()}\n      onCheckedChange={(v) => row.toggleSelected(!!v)}\n      aria-label=\"Select row\"\n    />\n  );\n}\n\nfunction prospectColumns(): ColumnDef<ProspectRow>[] {\n  return [\n    {\n      id: \"select\",\n      header: ({ table }) => <SelectAllHeader table={table} />,\n      cell: ({ row }) => <SelectRowCell row={row} />,\n    },"}},"hookAdditionalContexts":[],"toolCallId":"tool_0a490da7-ba9f-4c1d-908b-e73c62daa44","startedAtMs":"1782957823547"},"model_call_id":"5977d0c1-3ad5-42be-85f2-1e8828435224-32-wwjq","session_id":"6573c6ff-6012-4c40-8cb2-1911b390dd96","timestamp_ms":1782957823545}
