rganizationId, organizationId),\n      ),\n      with: { errors: true },\n    });\n\n    if (!batch) notFound();\n    return serializeImportBatch(batch, batch.errors);\n  });\n","message":"The file /Users/beckett/.cursor/worktrees/quiksend/phase-2-prospects/apps/web/src/lib/prospects.functions.ts has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"tool_12e3ef5a-b462-4059-afad-be59590c1ad","startedAtMs":"1782958076041","completedAtMs":"1782958081428"},"model_call_id":"5977d0c1-3ad5-42be-85f2-1e8828435224-47-beey","session_id":"6573c6ff-6012-4c40-8cb2-1911b390dd96","timestamp_ms":1782958081477}
