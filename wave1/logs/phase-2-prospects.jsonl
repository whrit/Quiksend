               <FormItem>\n                      <FormLabel>Status</FormLabel>\n                      <Select value={field.value} onValueChange={field.onChange}>\n                        <FormControl>\n                          <SelectTrigger>\n                            <SelectValue />\n                          </SelectTrigger>\n                        </FormControl>\n                        <SelectContent>\n                          {statusOptions.map((s) => (\n                            <SelectItem key={s} value={s}>\n                              {s}\n                            </SelectItem>\n                          ))}\n                        </SelectContent>\n                      </Select>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n                <Button type=\"submit\" disabled={form.formState.isSubmitting}>\n                  Save changes\n                </Button>\n              </form>\n            </Form>\n          </CardContent>\n        </Card>\n\n        <div className=\"flex flex-col gap-6\">\n          <Card>\n            <CardHeader>\n              <CardTitle>Company</CardTitle>\n            </CardHeader>\n            <CardContent className=\"text-sm\">\n              {company ? (\n                <dl className=\"space-y-2\">\n                  <div>\n                    <dt className=\"text-muted-foreground\">Name</dt>\n                    <dd>{company.name ?? \"—\"}</dd>\n                  </div>\n                  <div>\n                    <dt className=\"text-muted-foreground\">Domain</dt>\n                    <dd>{company.domain ?? \"—\"}</dd>\n                  </div>\n                  <div>\n                    <dt className=\"text-muted-foreground\">Industry</dt>\n                    <dd>{company.industry ?? \"—\"}</dd>\n                  </div>\n                </dl>\n              ) : (\n                <p className=\"text-muted-foreground\">No company linked.</p>\n              )}\n            </CardContent>\n          </Card>\n\n          <Card>\n            <CardHeader>\n              <CardTitle>Lists</CardTitle>\n            </CardHeader>\n            <CardContent>\n              {lists.length ? (\n                <ul className=\"list-inside list-disc text-sm\">\n                  {lists.map((l) => (\n                    <li key={l.id}>{l.name}</li>\n                  ))}\n                </ul>\n              ) : (\n                <p className=\"text-sm text-muted-foreground\">Not on any lists.</p>\n              )}\n            </CardContent>\n          </Card>\n        </div>\n      </div>\n\n      <Card>\n        <CardHeader>\n          <CardTitle>Timeline</CardTitle>\n          <CardDescription>Activity and field changes</CardDescription>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          <div>\n            <h3 className=\"mb-2 text-sm font-medium\">Field changes</h3>\n            <ul className=\"space-y-3 border-l pl-4\">\n              {timeline.map((event) => (\n                <li key={event.id} className=\"relative\">\n                  <span className=\"absolute -left-[21px] top-1.5 h-2 w-2 rounded-full bg-primary\" />\n                  <p className=\"text-sm font-medium\">{event.label}</p>\n                  <p className=\"text-xs text-muted-foreground\">\n                    {new Date(event.at).toLocaleString()} — {event.detail}\n                  </p>\n                </li>\n              ))}\n            </ul>\n          </div>\n          <Separator />\n          <div>\n            <h3 className=\"mb-1 text-sm font-medium text-muted-foreground\">\n              Sequence history (Phase 5)\n            </h3>\n            <p className=\"text-sm text-muted-foreground\">No enrollments yet.</p>\n          </div>\n          <div>\n            <h3 className=\"mb-1 text-sm font-medium text-muted-foreground\">Messages (Phase 4/7)</h3>\n            <p className=\"text-sm text-muted-foreground\">No messages yet.</p>\n          </div>\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n","afterFullFileContent":"import { zodResolver } from \"@hookform/resolvers/zod\";\nimport { Link, createFileRoute } from \"@tanstack/react-router\";\nimport { useForm } from \"react-hook-form\";\nimport { toast } from \"sonner\";\nimport { z } from \"zod\";\nimport { Badge } from \"@/components/ui/badge\";\nimport { Button, buttonVariants } from \"@/components/ui/button\";\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport {\n  Form,\n  FormControl,\n  FormField,\n  FormItem,\n  FormLabel,\n  FormMessage,\n} from \"@/components/ui/form\";\nimport { Input } from \"@/components/ui/input\";\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/components/ui/select\";\nimport { Separator } from \"@/components/ui/separator\";\nimport { getProspect, updateProspect } from \"@/lib/prospects.functions.ts\";\n\nconst statusOptions = [\n  \"new\",\n  \"active\",\n  \"replied\",\n  \"bounced\",\n  \"unsubscribed\",\n  \"do_not_contact\",\n] as const;\n\nconst editSchema = z.object({\n  firstName: z.string().optional(),\n  lastName: z.string().optional(),\n  title: z.string().optional(),\n  phone: z.string().optional(),\n  linkedinUrl: z.string().optional(),\n  timezone: z.string().optional(),\n  status: z.enum(statusOptions),\n});\n\nexport const Route = createFileRoute(\"/_protected/prospects/$id\")({\n  loader: async ({ params }) => getProspect({ data: { id: params.id } }),\n  component: ProspectDetailPage,\n});\n\nfunction ProspectDetailPage() {\n  const data = Route.useLoaderData();\n  const { prospect, company, lists } = data;\n\n  const form = useForm<z.infer<typeof editSchema>>({\n    resolver: zodResolver(editSchema),\n    values: {\n      firstName: prospect.firstName ?? \"\",\n      lastName: prospect.lastName ?? \"\",\n      title: prospect.title ?? \"\",\n      phone: prospect.phone ?? \"\",\n      linkedinUrl: prospect.linkedinUrl ?? \"\",\n      timezone: prospect.timezone ?? \"\",\n      status: prospect.status,\n    },\n  });\n\n  const onSave = form.handleSubmit(async (values) => {\n    try {\n      await updateProspect({\n        data: {\n          id: prospect.id,\n          patch: {\n            firstName: values.firstName || null,\n            lastName: values.lastName || null,\n            title: values.title || null,\n            phone: values.phone || null,\n            linkedinUrl: values.linkedinUrl || null,\n            timezone: values.timezone || null,\n            status: values.status,\n          },\n        },\n      });\n      toast.success(\"Prospect updated\");\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Update failed\");\n    }\n  });\n\n  const timeline = [\n    {\n      id: \"created\",\n      label: \"Created\",\n      at: prospect.createdAt,\n      detail: `Imported via ${prospect.source}`,\n    },\n    ...(prospect.updatedAt !== prospect.createdAt\n      ? [\n          {\n            id: \"updated\",\n            label: \"Updated\",\n            at: prospect.updatedAt,\n            detail: \"Fields changed\",\n          },\n        ]\n      : []),\n  ];\n\n  return (\n    <div className=\"mx-auto flex max-w-4xl flex-col gap-6\">\n      <div className=\"flex items-center gap-3\">\n        <Button variant=\"ghost\" size=\"sm\" asChild>\n          <Link to=\"/prospects\">← Back</Link>\n        </Button>\n        <h1 className=\"text-2xl font-semibold\">\n          {[prospect.firstName, prospect.lastName].filter(Boolean).join(\" \") || prospect.email}\n        </h1>\n        <Badge variant=\"secondary\">{prospect.status}</Badge>\n      </div>\n\n      <div className=\"grid gap-6 md:grid-cols-2\">\n        <Card>\n          <CardHeader>\n            <CardTitle>Contact</CardTitle>\n            <CardDescription>{prospect.email}</CardDescription>\n          </CardHeader>\n          <CardContent>\n            <Form {...form}>\n              <form onSubmit={onSave} className=\"flex flex-col gap-3\">\n                <FormField\n                  control={form.control}\n                  name=\"firstName\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>First name</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"lastName\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Last name</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"title\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Title</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"phone\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Phone</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"linkedinUrl\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>LinkedIn</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"timezone\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Timezone</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"status\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Status</FormLabel>\n                      <Select value={field.value} onValueChange={field.onChange}>\n                        <FormControl>\n                          <SelectTrigger>\n                            <SelectValue />\n                          </SelectTrigger>\n                        </FormControl>\n                        <SelectContent>\n                          {statusOptions.map((s) => (\n                            <SelectItem key={s} value={s}>\n                              {s}\n                            </SelectItem>\n                          ))}\n                        </SelectContent>\n                      </Select>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n                <Button type=\"submit\" disabled={form.formState.isSubmitting}>\n                  Save changes\n                </Button>\n              </form>\n            </Form>\n          </CardContent>\n        </Card>\n\n        <div className=\"flex flex-col gap-6\">\n          <Card>\n            <CardHeader>\n              <CardTitle>Company</CardTitle>\n            </CardHeader>\n            <CardContent className=\"text-sm\">\n              {company ? (\n                <dl className=\"space-y-2\">\n                  <div>\n                    <dt className=\"text-muted-foreground\">Name</dt>\n                    <dd>{company.name ?? \"—\"}</dd>\n                  </div>\n                  <div>\n                    <dt className=\"text-muted-foreground\">Domain</dt>\n                    <dd>{company.domain ?? \"—\"}</dd>\n                  </div>\n                  <div>\n                    <dt className=\"text-muted-foreground\">Industry</dt>\n                    <dd>{company.industry ?? \"—\"}</dd>\n                  </div>\n                </dl>\n              ) : (\n                <p className=\"text-muted-foreground\">No company linked.</p>\n              )}\n            </CardContent>\n          </Card>\n\n          <Card>\n            <CardHeader>\n              <CardTitle>Lists</CardTitle>\n            </CardHeader>\n            <CardContent>\n              {lists.length ? (\n                <ul className=\"list-inside list-disc text-sm\">\n                  {lists.map((l) => (\n                    <li key={l.id}>{l.name}</li>\n                  ))}\n                </ul>\n              ) : (\n                <p className=\"text-sm text-muted-foreground\">Not on any lists.</p>\n              )}\n            </CardContent>\n          </Card>\n        </div>\n      </div>\n\n      <Card>\n        <CardHeader>\n          <CardTitle>Timeline</CardTitle>\n          <CardDescription>Activity and field changes</CardDescription>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          <div>\n            <h3 className=\"mb-2 text-sm font-medium\">Field changes</h3>\n            <ul className=\"space-y-3 border-l pl-4\">\n              {timeline.map((event) => (\n                <li key={event.id} className=\"relative\">\n                  <span className=\"absolute -left-[21px] top-1.5 h-2 w-2 rounded-full bg-primary\" />\n                  <p className=\"text-sm font-medium\">{event.label}</p>\n                  <p className=\"text-xs text-muted-foreground\">\n                    {new Date(event.at).toLocaleString()} — {event.detail}\n                  </p>\n                </li>\n              ))}\n            </ul>\n          </div>\n          <Separator />\n          <div>\n            <h3 className=\"mb-1 text-sm font-medium text-muted-foreground\">\n              Sequence history (Phase 5)\n            </h3>\n            <p className=\"text-sm text-muted-foreground\">No enrollments yet.</p>\n          </div>\n          <div>\n            <h3 className=\"mb-1 text-sm font-medium text-muted-foreground\">Messages (Phase 4/7)</h3>\n            <p className=\"text-sm text-muted-foreground\">No messages yet.</p>\n          </div>\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n","message":"The file /Users/beckett/.cursor/worktrees/quiksend/phase-2-prospects/apps/web/src/routes/_protected/prospects/$id.tsx has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"tool_13fc76d6-5e24-4927-aac3-bd46ce552eb","startedAtMs":"1782958024747","completedAtMs":"1782958030431"},"model_call_id":"5977d0c1-3ad5-42be-85f2-1e8828435224-45-j9qf","session_id":"6573c6ff-6012-4c40-8cb2-1911b390dd96","timestamp_ms":1782958030431}
