       <Table>\n+          <TableHeader>\n+            {table.getHeaderGroups().map((hg) => (\n+              <TableRow key={hg.id}>\n+                {hg.headers.map((h) => (\n+                  <TableHead key={h.id}>\n+                    {h.isPlaceholder ? null : flexRender(h.column.columnDef.header, h.getContext())}\n+                  </TableHead>\n+                ))}\n+              </TableRow>\n+            ))}\n+          </TableHeader>\n+          <TableBody>\n+            {table.getRowModel().rows.length ? (\n+              table.getRowModel().rows.map((row) => (\n+                <TableRow key={row.id} data-state={row.getIsSelected() && \"selected\"}>\n+                  {row.getVisibleCells().map((cell) => (\n+                    <TableCell key={cell.id}>\n+                      {flexRender(cell.column.columnDef.cell, cell.getContext())}\n+                    </TableCell>\n+                  ))}\n+                </TableRow>\n+              ))\n+            ) : (\n+              <TableRow>\n+                <TableCell colSpan={columns.length} className=\"h-24 text-center\">\n+                  No prospects yet. Add one or import a CSV.\n+                </TableCell>\n+              </TableRow>\n+            )}\n+          </TableBody>\n+        </Table>\n+      </div>\n+\n+      <div className=\"flex justify-end gap-2\">\n+        {search.cursor && (\n+          <Button\n+            variant=\"outline\"\n+            onClick={() => applyFilters({ cursor: undefined })}\n+          >\n+            First page\n+          </Button>\n+        )}\n+        {prospects.nextCursor && (\n+          <Button\n+            variant=\"outline\"\n+            onClick={() =>\n+              applyFilters({ cursor: JSON.stringify(prospects.nextCursor) })\n+            }\n+          >\n+            Next page\n+          </Button>\n+        )}\n+      </div>\n+\n+      <Dialog open={addOpen} onOpenChange={setAddOpen}>\n+        <DialogContent>\n+          <DialogHeader>\n+            <DialogTitle>Add prospect</DialogTitle>\n+          </DialogHeader>\n+          <Form {...form}>\n+            <form onSubmit={onCreateProspect} className=\"flex flex-col gap-3\">\n+              <FormField\n+                control={form.control}\n+                name=\"email\"\n+                render={({ field }) => (\n+                  <FormItem>\n+                    <FormLabel>Email</FormLabel>\n+                    <FormControl>\n+                      <Input {...field} type=\"email\" />\n+                    </FormControl>\n+                    <FormMessage />\n+                  </FormItem>\n+                )}\n+              />\n+              <FormField\n+                control={form.control}\n+                name=\"firstName\"\n+                render={({ field }) => (\n+                  <FormItem>\n+                    <FormLabel>First name</FormLabel>\n+                    <FormControl>\n+                      <Input {...field} />\n+                    </FormControl>\n+                  </FormItem>\n+                )}\n+              />\n+              <FormField\n+                control={form.control}\n+                name=\"lastName\"\n+                render={({ field }) => (\n+                  <FormItem>\n+                    <FormLabel>Last name</FormLabel>\n+                    <FormControl>\n+                      <Input {...field} />\n+                    </FormControl>\n+                  </FormItem>\n+                )}\n+              />\n+              <FormField\n+                control={form.control}\n+                name=\"title\"\n+                render={({ field }) => (\n+                  <FormItem>\n+                    <FormLabel>Title</FormLabel>\n+                    <FormControl>\n+                      <Input {...field} />\n+                    </FormControl>\n+                  </FormItem>\n+                )}\n+              />\n+              <DialogFooter>\n+                <Button type=\"submit\">Create</Button>\n+              </DialogFooter>\n+            </form>\n+          </Form>\n+        </DialogContent>\n+      </Dialog>\n+\n+      <Dialog open={deleteOpen} onOpenChange={setDeleteOpen}>\n+        <DialogContent>\n+          <DialogHeader>\n+            <DialogTitle>Delete {selectedIds.length} prospect(s)?</DialogTitle>\n+          </DialogHeader>\n+          <p className=\"text-sm text-muted-foreground\">\n+            This soft-deletes the selected prospects. You can re-import them later.\n+          </p>\n+          <DialogFooter>\n+            <Button variant=\"outline\" onClick={() => setDeleteOpen(false)}>\n+              Cancel\n+            </Button>\n+            <Button variant=\"destructive\" onClick={() => void onBulkDelete()}>\n+              Delete\n+            </Button>\n+          </DialogFooter>\n+        </DialogContent>\n+      </Dialog>\n+\n+      <Dialog open={addListOpen} onOpenChange={setAddListOpen}>\n+        <DialogContent>\n+          <DialogHeader>\n+            <DialogTitle>Add to list</DialogTitle>\n+          </DialogHeader>\n+          <div className=\"flex flex-col gap-3\">\n+            <Select value={selectedListId} onValueChange={setSelectedListId}>\n+              <SelectTrigger>\n+                <SelectValue placeholder=\"Choose a list\" />\n+              </SelectTrigger>\n+              <SelectContent>\n+                {lists.map((l) => (\n+                  <SelectItem key={l.id} value={l.id}>\n+                    {l.name}\n+                  </SelectItem>\n+                ))}\n+              </SelectContent>\n+            </Select>\n+            <Button variant=\"link\" className=\"px-0\" onClick={() => setNewListOpen(true)}>\n+              Create new list\n+            </Button>\n+          </div>\n+          <DialogFooter>\n+            <Button onClick={() => void onAddToList()} disabled={!selectedListId}>\n+              Add\n+            </Button>\n+          </DialogFooter>\n+        </DialogContent>\n+      </Dialog>\n+\n+      <Dialog open={newListOpen} onOpenChange={setNewListOpen}>\n+        <DialogContent>\n+          <DialogHeader>\n+            <DialogTitle>Create list</DialogTitle>\n+          </DialogHeader>\n+          <Form {...newListForm}>\n+            <form onSubmit={onCreateList} className=\"flex flex-col gap-3\">\n+              <FormField\n+                control={newListForm.control}\n+                name=\"name\"\n+                render={({ field }) => (\n+                  <FormItem>\n+                    <FormLabel>Name</FormLabel>\n+                    <FormControl>\n+                      <Input {...field} />\n+                    </FormControl>\n+                  </FormItem>\n+                )}\n+              />\n+              <DialogFooter>\n+                <Button type=\"submit\">Create list</Button>\n+              </DialogFooter>\n+            </form>\n+          </Form>\n+        </DialogContent>\n+      </Dialog>\n+    </div>\n+  );\n+}","afterFullFileContent":"import { zodResolver } from \"@hookform/resolvers/zod\";\nimport { Link, createFileRoute, useNavigate } from \"@tanstack/react-router\";\nimport {\n  flexRender,\n  getCoreRowModel,\n  useReactTable,\n  type ColumnDef,\n  type RowSelectionState,\n} from \"@tanstack/react-table\";\nimport { MoreHorizontal, Plus, Upload } from \"lucide-react\";\nimport { useMemo, useState } from \"react\";\nimport { useForm } from \"react-hook-form\";\nimport { toast } from \"sonner\";\nimport { z } from \"zod\";\nimport { Badge } from \"@/components/ui/badge\";\nimport { Button } from \"@/components/ui/button\";\nimport { Checkbox } from \"@/components/ui/checkbox\";\nimport {\n  Dialog,\n  DialogContent,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n} from \"@/components/ui/dialog\";\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuItem,\n  DropdownMenuTrigger,\n} from \"@/components/ui/dropdown-menu\";\nimport {\n  Form,\n  FormControl,\n  FormField,\n  FormItem,\n  FormLabel,\n  FormMessage,\n} from \"@/components/ui/form\";\nimport { Input } from \"@/components/ui/input\";\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/components/ui/select\";\nimport {\n  Table,\n  TableBody,\n  TableCell,\n  TableHead,\n  TableHeader,\n  TableRow,\n} from \"@/components/ui/table\";\nimport {\n  addToList,\n  bulkDeleteProspects,\n  createList,\n  createProspect,\n  listCompanies,\n  listLists,\n  listProspects,\n} from \"@/lib/prospects.functions.ts\";\n\nconst searchSchema = z.object({\n  search: z.string().optional(),\n  status: z.string().optional(),\n  listId: z.string().optional(),\n  companyId: z.string().optional(),\n  cursor: z.string().optional(),\n});\n\ntype ProspectRow = Awaited<ReturnType<typeof listProspects>>[\"items\"][number];\n\nconst statusOptions = [\n  \"new\",\n  \"active\",\n  \"replied\",\n  \"bounced\",\n  \"unsubscribed\",\n  \"do_not_contact\",\n] as const;\n\nconst createProspectSchema = z.object({\n  email: z.string().min(1),\n  firstName: z.string().optional(),\n  lastName: z.string().optional(),\n  title: z.string().optional(),\n});\n\nexport const Route = createFileRoute(\"/_protected/prospects/\")({\n  validateSearch: (search) => searchSchema.parse(search),\n  loaderDeps: ({ search }) => ({ search }),\n  loader: async ({ deps }) => {\n    const { search } = deps;\n    const status = search.status\n      ? (search.status.split(\",\").filter(Boolean) as (typeof statusOptions)[number][])\n      : undefined;\n\n    const [prospects, lists, companies] = await Promise.all([\n      listProspects({\n        data: {\n          search: search.search,\n          status,\n          listId: search.listId,\n          companyId: search.companyId,\n          cursor: search.cursor\n            ? (JSON.parse(search.cursor) as { id: string; createdAt: string })\n            : undefined,\n          limit: 50,\n        },\n      }),\n      listLists({ data: {} }),\n      listCompanies({ data: { limit: 100 } }),\n    ]);\n\n    return { prospects, lists, companies: companies.items };\n  },\n  component: ProspectsPage,\n});\n\nfunction statusVariant(status: string): \"default\" | \"secondary\" | \"destructive\" | \"outline\" {\n  if (status === \"replied\" || status === \"active\") return \"default\";\n  if (status === \"bounced\" || status === \"do_not_contact\") return \"destructive\";\n  return \"secondary\";\n}\n\nfunction ProspectsPage() {\n  const navigate = useNavigate({ from: Route.fullPath });\n  const search = Route.useSearch();\n  const { prospects, lists, companies } = Route.useLoaderData();\n  const [rowSelection, setRowSelection] = useState<RowSelectionState>({});\n  const [addOpen, setAddOpen] = useState(false);\n  const [deleteOpen, setDeleteOpen] = useState(false);\n  const [addListOpen, setAddListOpen] = useState(false);\n  const [newListOpen, setNewListOpen] = useState(false);\n  const [selectedListId, setSelectedListId] = useState<string>(\"\");\n  const [localSearch, setLocalSearch] = useState(search.search ?? \"\");\n\n  const form = useForm<z.infer<typeof createProspectSchema>>({\n    resolver: zodResolver(createProspectSchema),\n    defaultValues: { email: \"\", firstName: \"\", lastName: \"\", title: \"\" },\n  });\n\n  const newListForm = useForm<{ name: string }>({\n    resolver: zodResolver(z.object({ name: z.string().min(1) })),\n    defaultValues: { name: \"\" },\n  });\n\n  const selectedIds = useMemo(\n    () =>\n      Object.entries(rowSelection)\n        .filter(([, v]) => v)\n        .map(([id]) => id),\n    [rowSelection],\n  );\n\n  const columns = useMemo<ColumnDef<ProspectRow>[]>(\n    () => [\n      {\n        id: \"select\",\n        header: ({ table }) => (\n          <Checkbox\n            checked={\n              table.getIsAllPageRowsSelected() ||\n              (table.getIsSomePageRowsSelected() && \"indeterminate\")\n            }\n            onCheckedChange={(v) => table.toggleAllPageRowsSelected(!!v)}\n            aria-label=\"Select all\"\n          />\n        ),\n        cell: ({ row }) => (\n          <Checkbox\n            checked={row.getIsSelected()}\n            onCheckedChange={(v) => row.toggleSelected(!!v)}\n            aria-label=\"Select row\"\n          />\n        ),\n      },\n      {\n        id: \"name\",\n        header: \"Name\",\n        cell: ({ row }) => {\n          const p = row.original;\n          const name = [p.firstName, p.lastName].filter(Boolean).join(\" \") || \"—\";\n          return (\n            <Link\n              to=\"/prospects/$id\"\n              params={{ id: p.id }}\n              className=\"font-medium hover:underline\"\n            >\n              {name}\n            </Link>\n          );\n        },\n      },\n      { accessorKey: \"email\", header: \"Email\" },\n      {\n        id: \"company\",\n        header: \"Company\",\n        cell: ({ row }) => row.original.companyName ?? \"—\",\n      },\n      { accessorKey: \"title\", header: \"Title\", cell: ({ getValue }) => getValue() ?? \"—\" },\n      {\n        accessorKey: \"status\",\n        header: \"Status\",\n        cell: ({ getValue }) => (\n          <Badge variant={statusVariant(String(getValue()))}>{String(getValue())}</Badge>\n        ),\n      },\n      {\n        accessorKey: \"source\",\n        header: \"Source\",\n        cell: ({ getValue }) => <Badge variant=\"outline\">{String(getValue())}</Badge>,\n      },\n      {\n        id: \"activity\",\n        header: \"Last activity\",\n        cell: ({ row }) => new Date(row.original.updatedAt).toLocaleDateString(),\n      },\n      {\n        id: \"actions\",\n        cell: ({ row }) => (\n          <DropdownMenu>\n            <DropdownMenuTrigger asChild>\n              <Button variant=\"ghost\" size=\"sm\">\n                <MoreHorizontal className=\"h-4 w-4\" />\n              </Button>\n            </DropdownMenuTrigger>\n            <DropdownMenuContent align=\"end\">\n              <DropdownMenuItem asChild>\n                <Link to=\"/prospects/$id\" params={{ id: row.original.id }}>\n                  View\n                </Link>\n              </DropdownMenuItem>\n            </DropdownMenuContent>\n          </DropdownMenu>\n        ),\n      },\n    ],\n    [],\n  );\n\n  const table = useReactTable({\n    data: prospects.items,\n    columns,\n    getCoreRowModel: getCoreRowModel(),\n    onRowSelectionChange: setRowSelection,\n    state: { rowSelection },\n    getRowId: (row) => row.id,\n  });\n\n  const applyFilters = (patch: Partial<typeof search>) => {\n    void navigate({\n      search: (prev) => ({ ...prev, ...patch, cursor: undefined }),\n    });\n  };\n\n  const onCreateProspect = form.handleSubmit(async (values) => {\n    try {\n      await createProspect({ data: values });\n      toast.success(\"Prospect created\");\n      setAddOpen(false);\n      form.reset();\n      void navigate({ search: (prev) => ({ ...prev }) });\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Failed to create prospect\");\n    }\n  });\n\n  const onBulkDelete = async () => {\n    try {\n      await bulkDeleteProspects({ data: { ids: selectedIds } });\n      toast.success(`Deleted ${selectedIds.length} prospect(s)`);\n      setDeleteOpen(false);\n      setRowSelection({});\n      void navigate({ search: (prev) => ({ ...prev }) });\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Bulk delete failed\");\n    }\n  };\n\n  const onAddToList = async () => {\n    if (!selectedListId) return;\n    try {\n      await addToList({ data: { listId: selectedListId, prospectIds: selectedIds } });\n      toast.success(\"Added to list\");\n      setAddListOpen(false);\n      setRowSelection({});\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Failed to add to list\");\n    }\n  };\n\n  const onCreateList = newListForm.handleSubmit(async (values) => {\n    try {\n      const list = await createList({ data: values });\n      toast.success(\"List created\");\n      setNewListOpen(false);\n      newListForm.reset();\n      setSelectedListId(list.id);\n      void navigate({ search: (prev) => ({ ...prev }) });\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Failed to create list\");\n    }\n  });\n\n  return (\n    <div className=\"mx-auto flex max-w-7xl flex-col gap-6\">\n      <div className=\"flex flex-wrap items-center justify-between gap-3\">\n        <div>\n          <h1 className=\"text-2xl font-semibold\">Prospects</h1>\n          <p className=\"text-sm text-muted-foreground\">\n            Manage contacts, lists, and CSV imports.\n          </p>\n        </div>\n        <div className=\"flex flex-wrap gap-2\">\n          <Button variant=\"outline\" asChild>\n            <Link to=\"/prospects/import\">\n              <Upload className=\"mr-2 h-4 w-4\" />\n              Import CSV\n            </Link>\n          </Button>\n          <Button onClick={() => setAddOpen(true)}>\n            <Plus className=\"mr-2 h-4 w-4\" />\n            Add prospect\n          </Button>\n        </div>\n      </div>\n\n      <div className=\"flex flex-wrap gap-3\">\n        <form\n          className=\"flex gap-2\"\n          onSubmit={(e) => {\n            e.preventDefault();\n            applyFilters({ search: localSearch || undefined });\n          }}\n        >\n          <Input\n            placeholder=\"Search email or name…\"\n            value={localSearch}\n            onChange={(e) => setLocalSearch(e.target.value)}\n            className=\"w-64\"\n          />\n          <Button type=\"submit\" variant=\"secondary\">\n            Search\n          </Button>\n        </form>\n\n        <Select\n          value={search.status ?? \"all\"}\n          onValueChange={(v) => applyFilters({ status: v === \"all\" ? undefined : v })}\n        >\n          <SelectTrigger className=\"w-44\">\n            <SelectValue placeholder=\"Status\" />\n          </SelectTrigger>\n          <SelectContent>\n            <SelectItem value=\"all\">All statuses</SelectItem>\n            {statusOptions.map((s) => (\n              <SelectItem key={s} value={s}>\n                {s}\n              </SelectItem>\n            ))}\n          </SelectContent>\n        </Select>\n\n        <Select\n          value={search.listId ?? \"all\"}\n          onValueChange={(v) => applyFilters({ listId: v === \"all\" ? undefined : v })}\n        >\n          <SelectTrigger className=\"w-44\">\n            <SelectValue placeholder=\"List\" />\n          </SelectTrigger>\n          <SelectContent>\n            <SelectItem value=\"all\">All lists</SelectItem>\n            {lists.map((l) => (\n              <SelectItem key={l.id} value={l.id}>\n                {l.name}\n              </SelectItem>\n            ))}\n          </SelectContent>\n        </Select>\n\n        <Select\n          value={search.companyId ?? \"all\"}\n          onValueChange={(v) => applyFilters({ companyId: v === \"all\" ? undefined : v })}\n        >\n          <SelectTrigger className=\"w-44\">\n            <SelectValue placeholder=\"Company\" />\n          </SelectTrigger>\n          <SelectContent>\n            <SelectItem value=\"all\">All companies</SelectItem>\n            {companies.map((c) => (\n              <SelectItem key={c.id} value={c.id}>\n                {c.name ?? c.domain ?? c.id}\n              </SelectItem>\n            ))}\n          </SelectContent>\n        </Select>\n      </div>\n\n      {selectedIds.length > 0 && (\n        <div className=\"flex items-center gap-2 rounded-md border bg-muted/40 px-3 py-2\">\n          <span className=\"text-sm\">{selectedIds.length} selected</span>\n          <Button size=\"sm\" variant=\"outline\" onClick={() => setAddListOpen(true)}>\n            Add to list\n          </Button>\n          <Button size=\"sm\" variant=\"destructive\" onClick={() => setDeleteOpen(true)}>\n            Delete\n          </Button>\n        </div>\n      )}\n\n      <div className=\"rounded-md border\">\n        <Table>\n          <TableHeader>\n            {table.getHeaderGroups().map((hg) => (\n              <TableRow key={hg.id}>\n                {hg.headers.map((h) => (\n                  <TableHead key={h.id}>\n                    {h.isPlaceholder ? null : flexRender(h.column.columnDef.header, h.getContext())}\n                  </TableHead>\n                ))}\n              </TableRow>\n            ))}\n          </TableHeader>\n          <TableBody>\n            {table.getRowModel().rows.length ? (\n              table.getRowModel().rows.map((row) => (\n                <TableRow key={row.id} data-state={row.getIsSelected() && \"selected\"}>\n                  {row.getVisibleCells().map((cell) => (\n                    <TableCell key={cell.id}>\n                      {flexRender(cell.column.columnDef.cell, cell.getContext())}\n                    </TableCell>\n                  ))}\n                </TableRow>\n              ))\n            ) : (\n              <TableRow>\n                <TableCell colSpan={columns.length} className=\"h-24 text-center\">\n                  No prospects yet. Add one or import a CSV.\n                </TableCell>\n              </TableRow>\n            )}\n          </TableBody>\n        </Table>\n      </div>\n\n      <div className=\"flex justify-end gap-2\">\n        {search.cursor && (\n          <Button\n            variant=\"outline\"\n            onClick={() => applyFilters({ cursor: undefined })}\n          >\n            First page\n          </Button>\n        )}\n        {prospects.nextCursor && (\n          <Button\n            variant=\"outline\"\n            onClick={() =>\n              applyFilters({ cursor: JSON.stringify(prospects.nextCursor) })\n            }\n          >\n            Next page\n          </Button>\n        )}\n      </div>\n\n      <Dialog open={addOpen} onOpenChange={setAddOpen}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>Add prospect</DialogTitle>\n          </DialogHeader>\n          <Form {...form}>\n            <form onSubmit={onCreateProspect} className=\"flex flex-col gap-3\">\n              <FormField\n                control={form.control}\n                name=\"email\"\n                render={({ field }) => (\n                  <FormItem>\n                    <FormLabel>Email</FormLabel>\n                    <FormControl>\n                      <Input {...field} type=\"email\" />\n                    </FormControl>\n                    <FormMessage />\n                  </FormItem>\n                )}\n              />\n              <FormField\n                control={form.control}\n                name=\"firstName\"\n                render={({ field }) => (\n                  <FormItem>\n                    <FormLabel>First name</FormLabel>\n                    <FormControl>\n                      <Input {...field} />\n                    </FormControl>\n                  </FormItem>\n                )}\n              />\n              <FormField\n                control={form.control}\n                name=\"lastName\"\n                render={({ field }) => (\n                  <FormItem>\n                    <FormLabel>Last name</FormLabel>\n                    <FormControl>\n                      <Input {...field} />\n                    </FormControl>\n                  </FormItem>\n                )}\n              />\n              <FormField\n                control={form.control}\n                name=\"title\"\n                render={({ field }) => (\n                  <FormItem>\n                    <FormLabel>Title</FormLabel>\n                    <FormControl>\n                      <Input {...field} />\n                    </FormControl>\n                  </FormItem>\n                )}\n              />\n              <DialogFooter>\n                <Button type=\"submit\">Create</Button>\n              </DialogFooter>\n            </form>\n          </Form>\n        </DialogContent>\n      </Dialog>\n\n      <Dialog open={deleteOpen} onOpenChange={setDeleteOpen}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>Delete {selectedIds.length} prospect(s)?</DialogTitle>\n          </DialogHeader>\n          <p className=\"text-sm text-muted-foreground\">\n            This soft-deletes the selected prospects. You can re-import them later.\n          </p>\n          <DialogFooter>\n            <Button variant=\"outline\" onClick={() => setDeleteOpen(false)}>\n              Cancel\n            </Button>\n            <Button variant=\"destructive\" onClick={() => void onBulkDelete()}>\n              Delete\n            </Button>\n          </DialogFooter>\n        </DialogContent>\n      </Dialog>\n\n      <Dialog open={addListOpen} onOpenChange={setAddListOpen}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>Add to list</DialogTitle>\n          </DialogHeader>\n          <div className=\"flex flex-col gap-3\">\n            <Select value={selectedListId} onValueChange={setSelectedListId}>\n              <SelectTrigger>\n                <SelectValue placeholder=\"Choose a list\" />\n              </SelectTrigger>\n              <SelectContent>\n                {lists.map((l) => (\n                  <SelectItem key={l.id} value={l.id}>\n                    {l.name}\n                  </SelectItem>\n                ))}\n              </SelectContent>\n            </Select>\n            <Button variant=\"link\" className=\"px-0\" onClick={() => setNewListOpen(true)}>\n              Create new list\n            </Button>\n          </div>\n          <DialogFooter>\n            <Button onClick={() => void onAddToList()} disabled={!selectedListId}>\n              Add\n            </Button>\n          </DialogFooter>\n        </DialogContent>\n      </Dialog>\n\n      <Dialog open={newListOpen} onOpenChange={setNewListOpen}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>Create list</DialogTitle>\n          </DialogHeader>\n          <Form {...newListForm}>\n            <form onSubmit={onCreateList} className=\"flex flex-col gap-3\">\n              <FormField\n                control={newListForm.control}\n                name=\"name\"\n                render={({ field }) => (\n                  <FormItem>\n                    <FormLabel>Name</FormLabel>\n                    <FormControl>\n                      <Input {...field} />\n                    </FormControl>\n                  </FormItem>\n                )}\n              />\n              <DialogFooter>\n                <Button type=\"submit\">Create list</Button>\n              </DialogFooter>\n            </form>\n          </Form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","message":"Wrote contents to /Users/beckett/.cursor/worktrees/quiksend/phase-2-prospects/apps/web/src/routes/_protected/prospects/index.tsx"}}},"hookAdditionalContexts":[],"toolCallId":"tool_a8703506-fde1-4ff4-a197-a5c9b8eaa42","startedAtMs":"1782957694033","completedAtMs":"1782957696019"},"model_call_id":"5977d0c1-3ad5-42be-85f2-1e8828435224-28-ugyx","session_id":"6573c6ff-6012-4c40-8cb2-1911b390dd96","timestamp_ms":1782957696010}
{"type":"tool_call","subtype":"started","call_id":"tool_a9a6a29d-9a6f-4d29-ac2b-56d3bc60880","tool_call":{"editToolCall":{"args":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-2-prospects/apps/web/src/routes/_protected/prospects/$id.tsx","streamContent":"import { zodResolver } from \"@hookform/resolvers/zod\";\nimport { Link, createFileRoute } from \"@tanstack/react-router\";\nimport { useForm } from \"react-hook-form\";\nimport { toast } from \"sonner\";\nimport { z } from \"zod\";\nimport { Badge } from \"@/components/ui/badge\";\nimport { Button } from \"@/components/ui/button\";\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport {\n  Form,\n  FormControl,\n  FormField,\n  FormItem,\n  FormLabel,\n  FormMessage,\n} from \"@/components/ui/form\";\nimport { Input } from \"@/components/ui/input\";\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/components/ui/select\";\nimport { Separator } from \"@/components/ui/separator\";\nimport { getProspect, updateProspect } from \"@/lib/prospects.functions.ts\";\n\nconst statusOptions = [\n  \"new\",\n  \"active\",\n  \"replied\",\n  \"bounced\",\n  \"unsubscribed\",\n  \"do_not_contact\",\n] as const;\n\nconst editSchema = z.object({\n  firstName: z.string().optional(),\n  lastName: z.string().optional(),\n  title: z.string().optional(),\n  phone: z.string().optional(),\n  linkedinUrl: z.string().optional(),\n  timezone: z.string().optional(),\n  status: z.enum(statusOptions),\n});\n\nexport const Route = createFileRoute(\"/_protected/prospects/$id\")({\n  loader: async ({ params }) => getProspect({ data: { id: params.id } }),\n  component: ProspectDetailPage,\n});\n\nfunction ProspectDetailPage() {\n  const data = Route.useLoaderData();\n  const { prospect, company, lists } = data;\n\n  const form = useForm<z.infer<typeof editSchema>>({\n    resolver: zodResolver(editSchema),\n    values: {\n      firstName: prospect.firstName ?? \"\",\n      lastName: prospect.lastName ?? \"\",\n      title: prospect.title ?? \"\",\n      phone: prospect.phone ?? \"\",\n      linkedinUrl: prospect.linkedinUrl ?? \"\",\n      timezone: prospect.timezone ?? \"\",\n      status: prospect.status,\n    },\n  });\n\n  const onSave = form.handleSubmit(async (values) => {\n    try {\n      await updateProspect({\n        data: {\n          id: prospect.id,\n          patch: {\n            firstName: values.firstName || null,\n            lastName: values.lastName || null,\n            title: values.title || null,\n            phone: values.phone || null,\n            linkedinUrl: values.linkedinUrl || null,\n            timezone: values.timezone || null,\n            status: values.status,\n          },\n        },\n      });\n      toast.success(\"Prospect updated\");\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Update failed\");\n    }\n  });\n\n  const timeline = [\n    {\n      id: \"created\",\n      label: \"Created\",\n      at: prospect.createdAt,\n      detail: `Imported via ${prospect.source}`,\n    },\n    ...(prospect.updatedAt.getTime() !== prospect.createdAt.getTime()\n      ? [\n          {\n            id: \"updated\",\n            label: \"Updated\",\n            at: prospect.updatedAt,\n            detail: \"Fields changed\",\n          },\n        ]\n      : []),\n  ];\n\n  return (\n    <div className=\"mx-auto flex max-w-4xl flex-col gap-6\">\n      <div className=\"flex items-center gap-3\">\n        <Button variant=\"ghost\" size=\"sm\" asChild>\n          <Link to=\"/prospects\">← Back</Link>\n        </Button>\n        <h1 className=\"text-2xl font-semibold\">\n          {[prospect.firstName, prospect.lastName].filter(Boolean).join(\" \") || prospect.email}\n        </h1>\n        <Badge variant=\"secondary\">{prospect.status}</Badge>\n      </div>\n\n      <div className=\"grid gap-6 md:grid-cols-2\">\n        <Card>\n          <CardHeader>\n            <CardTitle>Contact</CardTitle>\n            <CardDescription>{prospect.email}</CardDescription>\n          </CardHeader>\n          <CardContent>\n            <Form {...form}>\n              <form onSubmit={onSave} className=\"flex flex-col gap-3\">\n                <FormField\n                  control={form.control}\n                  name=\"firstName\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>First name</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"lastName\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Last name</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"title\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Title</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"phone\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Phone</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"linkedinUrl\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>LinkedIn</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"timezone\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Timezone</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"status\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Status</FormLabel>\n                      <Select value={field.value} onValueChange={field.onChange}>\n                        <FormControl>\n                          <SelectTrigger>\n                            <SelectValue />\n                          </SelectTrigger>\n                        </FormControl>\n                        <SelectContent>\n                          {statusOptions.map((s) => (\n                            <SelectItem key={s} value={s}>\n                              {s}\n                            </SelectItem>\n                          ))}\n                        </SelectContent>\n                      </Select>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n                <Button type=\"submit\" disabled={form.formState.isSubmitting}>\n                  Save changes\n                </Button>\n     