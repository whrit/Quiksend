tring(),\n    },\n    {\n      id: \"actions\",\n      header: \"\",\n      cell: ({ row }) => (\n        <DropdownMenu>\n          <DropdownMenuTrigger asChild>\n            <Button variant=\"ghost\" size=\"sm\">\n              <MoreHorizontal className=\"h-4 w-4\" />\n            </Button>\n          </DropdownMenuTrigger>\n          <DropdownMenuContent align=\"end\">\n            <DropdownMenuItem asChild>\n              <Link to=\"/prospects/$id\" params={{ id: row.original.id }}>\n                View\n              </Link>\n            </DropdownMenuItem>\n          </DropdownMenuContent>\n        </DropdownMenu>\n      ),\n    },\n  ];\n}\n\nfunction ProspectsPage() {"}},"hookAdditionalContexts":[],"toolCallId":"tool_ed242d69-09ab-4fe1-b7db-243e5b8d14f","startedAtMs":"1782957807569"},"model_call_id":"5977d0c1-3ad5-42be-85f2-1e8828435224-31-434p","session_id":"6573c6ff-6012-4c40-8cb2-1911b390dd96","timestamp_ms":1782957807567}
