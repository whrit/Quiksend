{"type":"tool_call","subtype":"completed","call_id":"tool_5d03fa50-304f-4e61-ad75-efe722de42d","tool_call":{"readToolCall":{"args":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-2-prospects/packages/core/src/index.ts"},"result":{"success":{"content":"/**\n * `@quiksend/core` — pure domain logic for the sequence engine.\n *\n * Nothing in this package performs I/O. It exports:\n *   • the enrollment state machine (transitions, guards, effects)\n *   • schedule/window/throttle math (used by the sequence-builder preview *and* the\n *     worker executor, so preview never drifts from reality — see Appendix A #2\n *     in Phases-2-10.md)\n *   • tenancy helpers (branded organization ids, orgFn context shape)\n *\n * The worker (`apps/worker`) interprets the effects the state machine emits; it\n * never lives inside this package.\n */\nexport * from \"./tenancy.ts\";\nexport * as schedule from \"./schedule/index.ts\";\nexport * as stateMachine from \"./state-machine/index.ts\";\n","isEmpty":false,"exceededLimit":false,"totalLines":17,"fileSize":726,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-2-prospects/packages/core/src/index.ts","readRange":{"startLine":1,"endLine":17},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_5d03fa50-304f-4e61-ad75-efe722de42d","startedAtMs":"1782957267740","completedAtMs":"1782957269690"},"model_call_id":"5977d0c1-3ad5-42be-85f2-1e8828435224-6-9xds","session_id":"6573c6ff-6012-4c40-8cb2-1911b390dd96","timestamp_ms":1782957269662}
