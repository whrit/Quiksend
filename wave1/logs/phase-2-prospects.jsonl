q(tables.list.organizationId, organizationId))\n      .orderBy(asc(tables.list.name));\n  });\n\nexport const addToList = orgFn({ method: \"POST\" })","isEmpty":false,"exceededLimit":false,"totalLines":849,"fileSize":25278,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-2-prospects/apps/web/src/lib/prospects.functions.ts","readRange":{"startLine":395,"endLine":594},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_35b97804-189a-4446-bf7b-b9ebb95f4c3","startedAtMs":"1782957949512","completedAtMs":"1782957951432"},"model_call_id":"5977d0c1-3ad5-42be-85f2-1e8828435224-40-clva","session_id":"6573c6ff-6012-4c40-8cb2-1911b390dd96","timestamp_ms":1782957952052}
