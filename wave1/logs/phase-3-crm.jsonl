ess.on(\"SIGTERM\", () => void shutdown(\"SIGTERM\"));\n}\n\nmain().catch((err: unknown) => {\n  logger.error({ err }, \"Worker failed to start\");\n  Sentry.captureException(err);\n  process.exit(1);\n});\n","isEmpty":false,"exceededLimit":false,"totalLines":58,"fileSize":1861,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-3-crm/apps/worker/src/index.ts","readRange":{"startLine":1,"endLine":58},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_9d4858bc-87c1-4a47-9d05-ed1a1d142b5","startedAtMs":"1782957204019","completedAtMs":"1782957206894"},"model_call_id":"33629d5d-d421-4b81-b0e8-701b7715f672-1-ja4e","session_id":"0f3e4653-146e-4400-8c92-9cdee71cb418","timestamp_ms":1782957206869}
