{"type":"tool_call","subtype":"completed","call_id":"tool_c54a1f8b-5a3f-4748-93aa-341d43d3b31","tool_call":{"readToolCall":{"args":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-3-crm/packages/integrations/src/nango.ts"},"result":{"success":{"content":"import { Nango } from \"@nangohq/node\";\nimport { env } from \"@quiksend/config\";\n\n/**\n * Long-lived Nango client. `env.NANGO_SECRET_KEY` is optional in the schema\n * (later phases turn it on) — call `getNango()` lazily and it throws if the\n * key is missing, giving a clear runtime error rather than a `.env` mystery.\n */\nlet cached: Nango | null = null;\n\nexport function getNango(): Nango {\n  if (cached) return cached;\n  if (!env.NANGO_SECRET_KEY) {\n    throw new Error(\n      \"NANGO_SECRET_KEY is not set. Configure Nango Cloud credentials before connecting a CRM or mailbox.\",\n    );\n  }\n  cached = new Nango({ secretKey: env.NANGO_SECRET_KEY });\n  return cached;\n}\n\n/** Test hook to reset the cached client between runs. */\nexport function resetNangoForTests(): void {\n  cached = null;\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":26,"fileSize":793,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-3-crm/packages/integrations/src/nango.ts","readRange":{"startLine":1,"endLine":26},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_c54a1f8b-5a3f-4748-93aa-341d43d3b31","startedAtMs":"1782957201907","completedAtMs":"1782957203750"},"model_call_id":"33629d5d-d421-4b81-b0e8-701b7715f672-1-ja4e","session_id":"0f3e4653-146e-4400-8c92-9cdee71cb418","timestamp_ms":1782957203745}
