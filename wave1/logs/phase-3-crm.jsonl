sforce\n             </Button>\n             <Button\n               variant=\"outline\"\n-              disabled={connectMutation.isPending}\n-              onClick={() => connectMutation.mutate(\"hubspot\")}\n+              disabled={connecting}\n+              onClick={() => void connectProvider(\"hubspot\")}\n             >\n               Connect HubSpot\n             </Button>","beforeFullFileContent":"import { Badge } from \"@/components/ui/badge\";\nimport { Button } from \"@/components/ui/button\";\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport {\n  disconnectCrm,\n  finalizeCrmConnection,\n  listCrmConnections,\n  createCrmConnectSession,\n  triggerCrmSync,\n} from \"@/lib/crm.functions\";\nimport { createFileRoute, Link } from \"@tanstack/react-router\";\nimport Nango from \"@nangohq/frontend\";\nimport { useMutation, useQuery, useQueryClient } from \"@tanstack/react-query\";\nimport { toast } from \"sonner\";\n\nexport const Route = createFileRoute(\"/_protected/settings/crm/\")({\n  component: CrmSettingsPage,\n  loader: async () => listCrmConnections(),\n});\n\nfunction CrmSettingsPage() {\n  const initial = Route.useLoaderData();\n  const queryClient = useQueryClient();\n  const { data: connections = initial } = useQuery({\n    queryKey: [\"crm-connections\"],\n    queryFn: () => listCrmConnections(),\n    initialData: initial,\n  });\n\n  const connectMutation = useMutation({\n    mutationFn: async (provider: \"salesforce\" | \"hubspot\") => {\n      const session = await createCrmConnectSession({ data: provider });\n      const nango = new Nango({ host: \"https://api.nango.dev\" });\n      return new Promise<void>((resolve, reject) => {\n        const connect = nango.openConnectUI({\n          onEvent: (event) => {\n            if (event.type === \"close\") {\n              reject(new Error(\"Connect UI closed\"));\n            }\n            if (event.type === \"connect\") {\n              void finalizeCrmConnection({\n                data: {\n                  provider,\n                  nangoConnectionId: event.payload.connectionId,\n                },\n              })\n                .then(() => resolve())\n                .catch(reject);\n            }\n          },\n        });\n        connect.setSessionToken(session.sessionToken);\n      });\n    },\n    onSuccess: () => {\n      toast.success(\"CRM connected\");\n      void queryClient.invalidateQueries({ queryKey: [\"crm-connections\"] });\n    },\n    onError: (err: Error) => toast.error(err.message || \"Failed to connect CRM\"),\n  });\n\n  const syncMutation = useMutation({\n    mutationFn: (input: { connectionId: string; model: \"Contact\" | \"Account\" | \"Company\" }) =>\n      triggerCrmSync({ data: input }),\n    onSuccess: () => toast.success(\"Sync enqueued\"),\n    onError: () => toast.error(\"Failed to enqueue sync\"),\n  });\n\n  const disconnectMutation = useMutation({\n    mutationFn: (connectionId: string) => disconnectCrm({ data: { connectionId } }),\n    onSuccess: () => {\n      toast.success(\"CRM disconnected\");\n      void queryClient.invalidateQueries({ queryKey: [\"crm-connections\"] });\n    },\n    onError: () => toast.error(\"Failed to disconnect\"),\n  });\n\n  return (\n    <div className=\"mx-auto max-w-3xl space-y-6\">\n      <div>\n        <h1 className=\"text-2xl font-semibold\">CRM connections</h1>\n        <p className=\"text-muted-foreground text-sm\">\n          Connect Salesforce or HubSpot to sync contacts and accounts into Quiksend.\n        </p>\n      </div>\n\n      {connections.length === 0 ? (\n        <Card>\n          <CardHeader>\n            <CardTitle>No CRM connected</CardTitle>\n            <CardDescription>\n              Connect a CRM to import contacts and companies on an incremental schedule.\n            </CardDescription>\n          </CardHeader>\n          <CardContent className=\"flex gap-3\">\n            <Button\n              disabled={connectMutation.isPending}\n              onClick={() => connectMutation.mutate(\"salesforce\")}\n            >\n              Connect Salesforce\n            </Button>\n            <Button\n              variant=\"outline\"\n              disabled={connectMutation.isPending}\n              onClick={() => connectMutation.mutate(\"hubspot\")}\n            >\n              Connect HubSpot\n            </Button>\n          </CardContent>\n        </Card>\n      ) : (\n        <div className=\"space-y-4\">\n          {connections.map((conn) => (\n            <Card key={conn.id}>\n              <CardHeader className=\"flex flex-row items-center justify-between\">\n                <div>\n                  <CardTitle className=\"capitalize\">{conn.provider}</CardTitle>\n                  <CardDescription>\n                    Last sync:{\" \"}\n                    {conn.lastSyncAt ? new Date(conn.lastSyncAt).toLocaleString() : \"Never\"}\n                  </CardDescription>\n                </div>\n                <Badge variant={conn.status === \"active\" ? \"default\" : \"secondary\"}>\n                  {conn.status}\n                </Badge>\n              </CardHeader>\n              <CardContent className=\"flex flex-wrap gap-2\">\n                <Button\n                  size=\"sm\"\n                  variant=\"outline\"\n                  onClick={() =>\n                    syncMutation.mutate({\n                      connectionId: conn.id,\n                      model: conn.provider === \"hubspot\" ? \"Company\" : \"Account\",\n                    })\n                  }\n                >\n                  Sync accounts\n                </Button>\n                <Button\n                  size=\"sm\"\n                  variant=\"outline\"\n                  onClick={() =>\n                    syncMutation.mutate({ connectionId: conn.id, model: \"Contact\" })\n                  }\n                >\n                  Sync contacts\n                </Button>\n                <Button size=\"sm\" variant=\"outline\" asChild>\n                  <Link to=\"/settings/crm/$connectionId/mapping\" params={{ connectionId: conn.id }}>\n                    Edit mapping\n                  </Link>\n                </Button>\n                <Button\n                  size=\"sm\"\n                  variant=\"destructive\"\n                  onClick={() => disconnectMutation.mutate(conn.id)}\n                >\n                  Disconnect\n                </Button>\n              </CardContent>\n            </Card>\n          ))}\n          <div className=\"flex gap-3\">\n            <Button\n              variant=\"outline\"\n              disabled={connectMutation.isPending}\n              onClick={() => connectMutation.mutate(\"salesforce\")}\n            >\n              Connect Salesforce\n            </Button>\n            <Button\n              variant=\"outline\"\n              disabled={connectMutation.isPending}\n              onClick={() => connectMutation.mutate(\"hubspot\")}\n            >\n              Connect HubSpot\n            </Button>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n","afterFullFileContent":"import { Badge } from \"@/components/ui/badge\";\nimport { Button } from \"@/components/ui/button\";\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport {\n  createCrmConnectSession,\n  disconnectCrm,\n  finalizeCrmConnection,\n  listCrmConnections,\n  triggerCrmSync,\n} from \"@/lib/crm.functions\";\nimport Nango from \"@nangohq/frontend\";\nimport { Link, createFileRoute, useRouter } from \"@tanstack/react-router\";\nimport { useState } from \"react\";\nimport { toast } from \"sonner\";\n\nexport const Route = createFileRoute(\"/_protected/settings/crm/\")({\n  component: CrmSettingsPage,\n  loader: async () => listCrmConnections(),\n});\n\nfunction CrmSettingsPage() {\n  const initial = Route.useLoaderData();\n  const router = useRouter();\n  const [connections, setConnections] = useState(initial);\n  const [connecting, setConnecting] = useState(false);\n\n  async function refresh(): Promise<void> {\n    const rows = await listCrmConnections();\n    setConnections(rows);\n    await router.invalidate();\n  }\n\n  async function connectProvider(provider: \"salesforce\" | \"hubspot\"): Promise<void> {\n    setConnecting(true);\n    try {\n      const session = await createCrmConnectSession({ data: provider });\n      const nango = new Nango({ host: \"https://api.nango.dev\" });\n      await new Promise<void>((resolve, reject) => {\n        const connect = nango.openConnectUI({\n          onEvent: (event) => {\n            if (event.type === \"close\") reject(new Error(\"Connect UI closed\"));\n            if (event.type === \"connect\") {\n              void finalizeCrmConnection({\n                data: {\n                  provider,\n                  nangoConnectionId: event.payload.connectionId,\n                },\n              })\n                .then(() => resolve())\n                .catch(reject);\n            }\n          },\n        });\n        connect.setSessionToken(session.sessionToken);\n      });\n      toast.success(\"CRM connected\");\n      await refresh();\n    } catch (err) {\n      const message = err instanceof Error ? err.message : \"Failed to connect CRM\";\n      toast.error(message);\n    } finally {\n      setConnecting(false);\n    }\n  }\n\n  async function runSync(\n    connectionId: string,\n    model: \"Contact\" | \"Account\" | \"Company\",\n  ): Promise<void> {\n    try {\n      await triggerCrmSync({ data: { connectionId, model } });\n      toast.success(\"Sync enqueued\");\n    } catch {\n      toast.error(\"Failed to enqueue sync\");\n    }\n  }\n\n  async function disconnect(connectionId: string): Promise<void> {\n    try {\n      await disconnectCrm({ data: { connectionId } });\n      toast.success(\"CRM disconnected\");\n      await refresh();\n    } catch {\n      toast.error(\"Failed to disconnect\");\n    }\n  }\n\n  return (\n    <div className=\"mx-auto max-w-3xl space-y-6\">\n      <div>\n        <h1 className=\"text-2xl font-semibold\">CRM connections</h1>\n        <p className=\"text-muted-foreground text-sm\">\n          Connect Salesforce or HubSpot to sync contacts and accounts into Quiksend.\n        </p>\n      </div>\n\n      {connections.length === 0 ? (\n        <Card>\n          <CardHeader>\n            <CardTitle>No CRM connected</CardTitle>\n            <CardDescription>\n              Connect a CRM to import contacts and companies on an incremental schedule.\n            </CardDescription>\n          </CardHeader>\n          <CardContent className=\"flex gap-3\">\n            <Button disabled={connecting} onClick={() => void connectProvider(\"salesforce\")}>\n              Connect Salesforce\n            </Button>\n            <Button\n              variant=\"outline\"\n              disabled={connecting}\n              onClick={() => void connectProvider(\"hubspot\")}\n            >\n              Connect HubSpot\n            </Button>\n          </CardContent>\n        </Card>\n      ) : (\n        <div className=\"space-y-4\">\n          {connections.map((conn) => (\n            <Card key={conn.id}>\n              <CardHeader className=\"flex flex-row items-center justify-between\">\n                <div>\n                  <CardTitle className=\"capitalize\">{conn.provider}</CardTitle>\n                  <CardDescription>\n                    Last sync:{\" \"}\n                    {conn.lastSyncAt ? new Date(conn.lastSyncAt).toLocaleString() : \"Never\"}\n                  </CardDescription>\n                </div>\n                <Badge variant={conn.status === \"active\" ? \"default\" : \"secondary\"}>\n                  {conn.status}\n                </Badge>\n              </CardHeader>\n              <CardContent className=\"flex flex-wrap gap-2\">\n                <Button\n                  size=\"sm\"\n                  variant=\"outline\"\n                  onClick={() =>\n                    void runSync(\n                      conn.id,\n                      conn.provider === \"hubspot\" ? \"Company\" : \"Account\",\n                    )\n                  }\n                >\n                  Sync accounts\n                </Button>\n                <Button\n                  size=\"sm\"\n                  variant=\"outline\"\n                  onClick={() => void runSync(conn.id, \"Contact\")}\n                >\n                  Sync contacts\n                </Button>\n                <Button size=\"sm\" variant=\"outline\" asChild>\n                  <Link to=\"/settings/crm/$connectionId/mapping\" params={{ connectionId: conn.id }}>\n                    Edit mapping\n                  </Link>\n                </Button>\n                <Button\n                  size=\"sm\"\n                  variant=\"destructive\"\n                  onClick={() => void disconnect(conn.id)}\n                >\n                  Disconnect\n                </Button>\n              </CardContent>\n            </Card>\n          ))}\n          <div className=\"flex gap-3\">\n            <Button\n              variant=\"outline\"\n              disabled={connecting}\n              onClick={() => void connectProvider(\"salesforce\")}\n            >\n              Connect Salesforce\n            </Button>\n            <Button\n              variant=\"outline\"\n              disabled={connecting}\n              onClick={() => void connectProvider(\"hubspot\")}\n            >\n              Connect HubSpot\n            </Button>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n","message":"Wrote contents to /Users/beckett/.cursor/worktrees/quiksend/phase-3-crm/apps/web/src/routes/_protected/settings/crm/index.tsx"}}},"hookAdditionalContexts":[],"toolCallId":"tool_d97858df-48b5-46ed-ae70-5ee8003a38a","startedAtMs":"1782957792346","completedAtMs":"1782957797620"},"model_call_id":"33629d5d-d421-4b81-b0e8-701b7715f672-32-65l1","session_id":"0f3e4653-146e-4400-8c92-9cdee71cb418","timestamp_ms":1782957797615}
{"type":"tool_call","subtype":"started","call_id":"tool_c8726bfb-47da-4071-9a6d-0b80db92de2","tool_call":{"editToolCall":{"args":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-3-crm/apps/web/src/routes/_protected/settings/crm/$connectionId/mapping.tsx","streamContent":"import { Button } from \"@/components/ui/button\";\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\nimport { listCrmConnections, updateFieldMapping } from \"@/lib/crm.functions\";\nimport { getProviderConfig } from \"@quiksend/integrations/providers\";\nimport type { CompanyField, CrmProvider, ProspectField } from \"@quiksend/integrations/providers\";\nimport { Link, createFileRoute, notFound } from \"@tanstack/react-router\";\nimport { useState } from \"react\";\nimport { toast } from \"sonner\";\n\nexport const Route = createFileRoute(\"/_protected/settings/crm/$connectionId/mapping\")({\n  component: MappingPage,\n  loader: async ({ params }) => {\n    const connections = await listCrmConnections();\n    const connection = connections.find((c) => c.id === params.connectionId);\n    if (!connection) throw notFound();\n    const defaults = getProviderConfig(connection.provider as CrmProvider).defaultFieldMapping;\n    const mapping = (connection.fieldMapping ?? defaults) as {\n      prospect: Record<ProspectField, string>;\n      company: Record<CompanyField, string>;\n    };\n    return { connection, defaults, mapping };\n  },\n});\n\nfunction MappingPage() {\n  const { connection, defaults, mapping: initial } = Route.useLoaderData();\n  const [mapping, setMapping] = useState(initial);\n  const [saving, setSaving] = useState(false);\n\n  async function save(): Promise<void> {\n    setSaving(true);\n    try {\n      await updateFieldMapping({ data: { connectionId: connection.id, mapping } });\n      toast.success(\"Field mapping saved\");\n    } catch {\n      toast.error(\"Failed to save mapping\");\n    } finally {\n      setSaving(false);\n    }\n  }\n\n  function resetProspect(): void {\n    setMapping((m) => ({ ...m, prospect: { ...defaults.prospect } }));\n  }\n\n  function resetCompany(): void {\n    setMapping((m) => ({ ...m, company: { ...defaults.company } }));\n  }\n\n  const prospectFields = Object.keys(defaults.prospect) as ProspectField[];\n  const companyFields = Object.keys(defaults.company) as CompanyField[];\n\n  return (\n    <div className=\"mx-auto max-w-3xl space-y-6\">\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-semibold capitalize\">{connection.provider} field mapping</h1>\n          <p className=\"text-muted-foreground text-sm\">\n            Map Quiksend fields to {connection.provider} property names.\n          </p>\n        </div>\n        <Button variant=\"outline\" asChild>\n          <Link to=\"/settings/crm\">Back</Link>\n        </Button>\n      </div>\n\n      <Card>\n        <CardHeader className=\"flex flex-row items-center justify-between\">\n          <div>\n            <CardTitle>Prospect fields</CardTitle>\n            <CardDescription>Left: Quiksend field. Right: CRM field name.</CardDescription>\n          </div>\n          <Button size=\"sm\" variant=\"ghost\" onClick={resetProspect}>\n            Reset to default\n          </Button>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          {prospectFields.map((field) => (\n            <div key={field} className=\"grid grid-cols-2 items-center gap-4\">\n              <Label className=\"font-mono text-sm\">{field}</Label>\n              <Input\n                value={mapping.prospect[field] ?? \"\"}\n                onChange={(e) =>\n                  setMapping((m) => ({\n                    ...m,\n                    prospect: { ...m.prospect, [field]: e.target.value },\n                  }))\n                }\n              />\n            </div>\n          ))}\n        </CardContent>\n      </Card>\n\n      <Card>\n        <CardHeader className=\"flex flex-row items-center justify-between\">\n          <div>\n            <CardTitle>Company fields</CardTitle>\n            <CardDescription>Left: Quiksend field. Right: CRM field name.</CardDescription>\n          </div>\n          <Button size=\"sm\" variant=\"ghost\" onClick={resetCompany}>\n            Reset to default\n          </Button>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          {companyFields.map((field) => (\n            <div key={field} className=\"grid grid-cols-2 items-center gap-4\">\n              <Label className=\"font-mono text-sm\">{field}</Label>\n              <Input\n                value={mapping.company[field] ?? \"\"}\n                onChange={(e) =>\n                  setMapping((m) => ({\n                    ...m,\n                    company: { ...m.company, [field]: e.target.value },\n                  }))\n                }\n              />\n            </div>\n          ))}\n        </CardContent>\n      </Card>\n\n      <Button disabled={saving} onClick={() => void save()}>\n        Save mapping\n      </Button>\n    </div>\n  );\n}\n"}},"hookAdditionalContexts":[],"toolCallId":"tool_c8726bfb-47da-4071-9a6d-0b80db92de2","startedAtMs":"1782957803746"},"model_call_id":"33629d5d-d421-4b81-b0e8-701b7715f672-32-65l1","session_id":"0f3e4653-146e-4400-8c92-9cdee71cb418","timestamp_ms":1782957803826}
