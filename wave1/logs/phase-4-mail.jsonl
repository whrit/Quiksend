{"type":"tool_call","subtype":"completed","call_id":"tool_128e5fe1-9eb6-4928-9b18-fb7b804f725","tool_call":{"editToolCall":{"args":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/compose.tsx","streamContent":"type MailboxRow = PublicMailbox;"},"result":{"success":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/compose.tsx","linesAdded":1,"linesRemoved":1,"diffString":"--- a//Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/compose.tsx\n+++ b//Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/compose.tsx\n@@ -30,7 +30,7 @@\n   component: ComposePage,\n });\n \n-type MailboxRow = Awaited<ReturnType<typeof listMailboxes>>[number];\n+type MailboxRow = PublicMailbox;\n \n function ComposePage() {\n   const [mailboxes, setMailboxes] = useState<MailboxRow[]>([]);","beforeFullFileContent":"import { createFileRoute } from \"@tanstack/react-router\";\nimport { Check, ChevronsUpDown, Loader2 } from \"lucide-react\";\nimport { useEffect, useState } from \"react\";\nimport { toast } from \"sonner\";\nimport { Button } from \"@/components/ui/button\";\nimport {\n  Command,\n  CommandEmpty,\n  CommandGroup,\n  CommandInput,\n  CommandItem,\n  CommandList,\n} from \"@/components/ui/command\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\nimport { Popover, PopoverContent, PopoverTrigger } from \"@/components/ui/popover\";\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/components/ui/select\";\nimport { Textarea } from \"@/components/ui/textarea\";\nimport { cn } from \"@/lib/utils\";\nimport { searchProspects, sendComposedMessage } from \"@/lib/compose.functions\";\nimport { listMailboxes, type PublicMailbox } from \"@/lib/mailboxes.functions\";\n\nexport const Route = createFileRoute(\"/_protected/compose\")({\n  component: ComposePage,\n});\n\ntype MailboxRow = Awaited<ReturnType<typeof listMailboxes>>[number];\n\nfunction ComposePage() {\n  const [mailboxes, setMailboxes] = useState<MailboxRow[]>([]);\n  const [mailboxId, setMailboxId] = useState(\"\");\n  const [prospectId, setProspectId] = useState(\"\");\n  const [prospectLabel, setProspectLabel] = useState(\"\");\n  const [prospectOpen, setProspectOpen] = useState(false);\n  const [prospectQuery, setProspectQuery] = useState(\"\");\n  const [prospectResults, setProspectResults] = useState<\n    { id: string; label: string; email: string }[]\n  >([]);\n  const [searching, setSearching] = useState(false);\n  const [subject, setSubject] = useState(\"\");\n  const [bodyHtml, setBodyHtml] = useState(\"\");\n  const [sending, setSending] = useState(false);\n  const [lastMessageId, setLastMessageId] = useState<string | null>(null);\n\n  useEffect(() => {\n    void listMailboxes()\n      .then((rows) => {\n        setMailboxes(rows);\n        if (rows[0] && !mailboxId) setMailboxId(rows[0].id);\n      })\n      .catch((err: Error) => toast.error(err.message));\n  }, [mailboxId]);\n\n  useEffect(() => {\n    if (prospectQuery.trim().length < 2) {\n      setProspectResults([]);\n      return;\n    }\n    const handle = setTimeout(() => {\n      setSearching(true);\n      void searchProspects({ data: { query: prospectQuery, limit: 10 } })\n        .then((rows) => setProspectResults(rows))\n        .catch(() => setProspectResults([]))\n        .finally(() => setSearching(false));\n    }, 300);\n    return () => clearTimeout(handle);\n  }, [prospectQuery]);\n\n  const handleSend = async () => {\n    if (!mailboxId || !prospectId || !subject.trim() || !bodyHtml.trim()) {\n      toast.error(\"Mailbox, prospect, subject, and body are required\");\n      return;\n    }\n    setSending(true);\n    try {\n      const result = await sendComposedMessage({\n        data: {\n          mailboxId,\n          prospectId,\n          subject,\n          bodyHtml,\n          bodyText: bodyHtml.replace(/<[^>]+>/g, \" \").trim(),\n        },\n      });\n      setLastMessageId(result.messageId);\n      toast.success(`Sent — Message-Id ${result.messageId}`);\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Send failed\");\n    } finally {\n      setSending(false);\n    }\n  };\n\n  return (\n    <div className=\"mx-auto max-w-2xl space-y-6\">\n      <div>\n        <h1 className=\"text-2xl font-semibold\">Compose</h1>\n        <p className=\"text-sm text-muted-foreground\">\n          Send a one-off email and capture the thread anchor for follow-up sequences.\n        </p>\n      </div>\n\n      <div className=\"space-y-4 rounded-lg border p-6\">\n        <div className=\"space-y-2\">\n          <Label>Mailbox</Label>\n          <Select value={mailboxId} onValueChange={setMailboxId}>\n            <SelectTrigger>\n              <SelectValue placeholder=\"Select mailbox\" />\n            </SelectTrigger>\n            <SelectContent>\n              {mailboxes.map((mb) => (\n                <SelectItem key={mb.id} value={mb.id}>\n                  {mb.fromName ? `${mb.fromName} <${mb.address}>` : mb.address}\n                </SelectItem>\n              ))}\n            </SelectContent>\n          </Select>\n        </div>\n\n        <div className=\"space-y-2\">\n          <Label>Prospect</Label>\n          <Popover open={prospectOpen} onOpenChange={setProspectOpen}>\n            <PopoverTrigger asChild>\n              <Button variant=\"outline\" className=\"w-full justify-between font-normal\">\n                {prospectLabel || \"Search prospects…\"}\n                <ChevronsUpDown className=\"ml-2 h-4 w-4 shrink-0 opacity-50\" />\n              </Button>\n            </PopoverTrigger>\n            <PopoverContent className=\"w-[--radix-popover-trigger-width] p-0\" align=\"start\">\n              <Command shouldFilter={false}>\n                <CommandInput\n                  placeholder=\"Type name or email…\"\n                  value={prospectQuery}\n                  onValueChange={setProspectQuery}\n                />\n                <CommandList>\n                  {searching ? (\n                    <div className=\"flex justify-center py-4\">\n                      <Loader2 className=\"h-4 w-4 animate-spin\" />\n                    </div>\n                  ) : (\n                    <>\n                      <CommandEmpty>No prospects found.</CommandEmpty>\n                      <CommandGroup>\n                        {prospectResults.map((p) => (\n                          <CommandItem\n                            key={p.id}\n                            value={p.id}\n                            onSelect={() => {\n                              setProspectId(p.id);\n                              setProspectLabel(`${p.label} (${p.email})`);\n                              setProspectOpen(false);\n                            }}\n                          >\n                            <Check\n                              className={cn(\n                                \"mr-2 h-4 w-4\",\n                                prospectId === p.id ? \"opacity-100\" : \"opacity-0\",\n                              )}\n                            />\n                            {p.label} — {p.email}\n                          </CommandItem>\n                        ))}\n                      </CommandGroup>\n                    </>\n                  )}\n                </CommandList>\n              </Command>\n            </PopoverContent>\n          </Popover>\n        </div>\n\n        <div className=\"space-y-2\">\n          <Label htmlFor=\"subject\">Subject</Label>\n          <Input id=\"subject\" value={subject} onChange={(e) => setSubject(e.target.value)} />\n        </div>\n\n        <div className=\"space-y-2\">\n          <Label htmlFor=\"body\">Body</Label>\n          <Textarea\n            id=\"body\"\n            rows={10}\n            value={bodyHtml}\n            onChange={(e) => setBodyHtml(e.target.value)}\n            placeholder=\"Write your message…\"\n          />\n        </div>\n\n        <Button onClick={() => void handleSend()} disabled={sending}>\n          {sending ? <Loader2 className=\"h-4 w-4 animate-spin\" /> : \"Send\"}\n        </Button>\n      </div>\n\n      {lastMessageId ? (\n        <div className=\"rounded-lg border bg-muted/40 p-4 text-sm\">\n          <p>\n            Sent with Message-Id: <code className=\"text-xs\">{lastMessageId}</code>\n          </p>\n          <a\n            className=\"text-primary underline\"\n            href={`/sequences/new?anchorMessageId=${encodeURIComponent(lastMessageId)}`}\n          >\n            Start a follow-up sequence from this message\n          </a>\n        </div>\n      ) : null}\n    </div>\n  );\n}\n","afterFullFileContent":"import { createFileRoute } from \"@tanstack/react-router\";\nimport { Check, ChevronsUpDown, Loader2 } from \"lucide-react\";\nimport { useEffect, useState } from \"react\";\nimport { toast } from \"sonner\";\nimport { Button } from \"@/components/ui/button\";\nimport {\n  Command,\n  CommandEmpty,\n  CommandGroup,\n  CommandInput,\n  CommandItem,\n  CommandList,\n} from \"@/components/ui/command\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\nimport { Popover, PopoverContent, PopoverTrigger } from \"@/components/ui/popover\";\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/components/ui/select\";\nimport { Textarea } from \"@/components/ui/textarea\";\nimport { cn } from \"@/lib/utils\";\nimport { searchProspects, sendComposedMessage } from \"@/lib/compose.functions\";\nimport { listMailboxes, type PublicMailbox } from \"@/lib/mailboxes.functions\";\n\nexport const Route = createFileRoute(\"/_protected/compose\")({\n  component: ComposePage,\n});\n\ntype MailboxRow = PublicMailbox;\n\nfunction ComposePage() {\n  const [mailboxes, setMailboxes] = useState<MailboxRow[]>([]);\n  const [mailboxId, setMailboxId] = useState(\"\");\n  const [prospectId, setProspectId] = useState(\"\");\n  const [prospectLabel, setProspectLabel] = useState(\"\");\n  const [prospectOpen, setProspectOpen] = useState(false);\n  const [prospectQuery, setProspectQuery] = useState(\"\");\n  const [prospectResults, setProspectResults] = useState<\n    { id: string; label: string; email: string }[]\n  >([]);\n  const [searching, setSearching] = useState(false);\n  const [subject, setSubject] = useState(\"\");\n  const [bodyHtml, setBodyHtml] = useState(\"\");\n  const [sending, setSending] = useState(false);\n  const [lastMessageId, setLastMessageId] = useState<string | null>(null);\n\n  useEffect(() => {\n    void listMailboxes()\n      .then((rows) => {\n        setMailboxes(rows);\n        if (rows[0] && !mailboxId) setMailboxId(rows[0].id);\n      })\n      .catch((err: Error) => toast.error(err.message));\n  }, [mailboxId]);\n\n  useEffect(() => {\n    if (prospectQuery.trim().length < 2) {\n      setProspectResults([]);\n      return;\n    }\n    const handle = setTimeout(() => {\n      setSearching(true);\n      void searchProspects({ data: { query: prospectQuery, limit: 10 } })\n        .then((rows) => setProspectResults(rows))\n        .catch(() => setProspectResults([]))\n        .finally(() => setSearching(false));\n    }, 300);\n    return () => clearTimeout(handle);\n  }, [prospectQuery]);\n\n  const handleSend = async () => {\n    if (!mailboxId || !prospectId || !subject.trim() || !bodyHtml.trim()) {\n      toast.error(\"Mailbox, prospect, subject, and body are required\");\n      return;\n    }\n    setSending(true);\n    try {\n      const result = await sendComposedMessage({\n        data: {\n          mailboxId,\n          prospectId,\n          subject,\n          bodyHtml,\n          bodyText: bodyHtml.replace(/<[^>]+>/g, \" \").trim(),\n        },\n      });\n      setLastMessageId(result.messageId);\n      toast.success(`Sent — Message-Id ${result.messageId}`);\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Send failed\");\n    } finally {\n      setSending(false);\n    }\n  };\n\n  return (\n    <div className=\"mx-auto max-w-2xl space-y-6\">\n      <div>\n        <h1 className=\"text-2xl font-semibold\">Compose</h1>\n        <p className=\"text-sm text-muted-foreground\">\n          Send a one-off email and capture the thread anchor for follow-up sequences.\n        </p>\n      </div>\n\n      <div className=\"space-y-4 rounded-lg border p-6\">\n        <div className=\"space-y-2\">\n          <Label>Mailbox</Label>\n          <Select value={mailboxId} onValueChange={setMailboxId}>\n            <SelectTrigger>\n              <SelectValue placeholder=\"Select mailbox\" />\n            </SelectTrigger>\n            <SelectContent>\n              {mailboxes.map((mb) => (\n                <SelectItem key={mb.id} value={mb.id}>\n                  {mb.fromName ? `${mb.fromName} <${mb.address}>` : mb.address}\n                </SelectItem>\n              ))}\n            </SelectContent>\n          </Select>\n        </div>\n\n        <div className=\"space-y-2\">\n          <Label>Prospect</Label>\n          <Popover open={prospectOpen} onOpenChange={setProspectOpen}>\n            <PopoverTrigger asChild>\n              <Button variant=\"outline\" className=\"w-full justify-between font-normal\">\n                {prospectLabel || \"Search prospects…\"}\n                <ChevronsUpDown className=\"ml-2 h-4 w-4 shrink-0 opacity-50\" />\n              </Button>\n            </PopoverTrigger>\n            <PopoverContent className=\"w-[--radix-popover-trigger-width] p-0\" align=\"start\">\n              <Command shouldFilter={false}>\n                <CommandInput\n                  placeholder=\"Type name or email…\"\n                  value={prospectQuery}\n                  onValueChange={setProspectQuery}\n                />\n                <CommandList>\n                  {searching ? (\n                    <div className=\"flex justify-center py-4\">\n                      <Loader2 className=\"h-4 w-4 animate-spin\" />\n                    </div>\n                  ) : (\n                    <>\n                      <CommandEmpty>No prospects found.</CommandEmpty>\n                      <CommandGroup>\n                        {prospectResults.map((p) => (\n                          <CommandItem\n                            key={p.id}\n                            value={p.id}\n                            onSelect={() => {\n                              setProspectId(p.id);\n                              setProspectLabel(`${p.label} (${p.email})`);\n                              setProspectOpen(false);\n                            }}\n                          >\n                            <Check\n                              className={cn(\n                                \"mr-2 h-4 w-4\",\n                                prospectId === p.id ? \"opacity-100\" : \"opacity-0\",\n                              )}\n                            />\n                            {p.label} — {p.email}\n                          </CommandItem>\n                        ))}\n                      </CommandGroup>\n                    </>\n                  )}\n                </CommandList>\n              </Command>\n            </PopoverContent>\n          </Popover>\n        </div>\n\n        <div className=\"space-y-2\">\n          <Label htmlFor=\"subject\">Subject</Label>\n          <Input id=\"subject\" value={subject} onChange={(e) => setSubject(e.target.value)} />\n        </div>\n\n        <div className=\"space-y-2\">\n          <Label htmlFor=\"body\">Body</Label>\n          <Textarea\n            id=\"body\"\n            rows={10}\n            value={bodyHtml}\n            onChange={(e) => setBodyHtml(e.target.value)}\n            placeholder=\"Write your message…\"\n          />\n        </div>\n\n        <Button onClick={() => void handleSend()} disabled={sending}>\n          {sending ? <Loader2 className=\"h-4 w-4 animate-spin\" /> : \"Send\"}\n        </Button>\n      </div>\n\n      {lastMessageId ? (\n        <div className=\"rounded-lg border bg-muted/40 p-4 text-sm\">\n          <p>\n            Sent with Message-Id: <code className=\"text-xs\">{lastMessageId}</code>\n          </p>\n          <a\n            className=\"text-primary underline\"\n            href={`/sequences/new?anchorMessageId=${encodeURIComponent(lastMessageId)}`}\n          >\n            Start a follow-up sequence from this message\n          </a>\n        </div>\n      ) : null}\n    </div>\n  );\n}\n","message":"The file /Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/compose.tsx has been updated."}}},"hookAdditionalContexts":[],"toolCallId":"tool_128e5fe1-9eb6-4928-9b18-fb7b804f725","startedAtMs":"1782958009901","completedAtMs":"1782958014033"},"model_call_id":"7e5022f7-c767-4b04-a8e4-816de5d91a39-51-w0r0","session_id":"96149331-134f-48b3-9ea0-fe7607af1532","timestamp_ms":1782958014192}
{"type":"tool_call","subtype":"completed","call_id":"tool_f07435c7-b069-4f33-a103-9f676d92708","tool_call":{"editToolCall":{"args":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/settings/mailboxes/new.tsx","streamContent":"const formSchema = z.object({\n  address: z.string().email(),\n  fromName: z.string().optional(),\n  host: z.string().min(1),\n  port: z.number().int().positive(),\n  secure: z.boolean().optional(),\n  authUser: z.string().optional(),\n  authPass: z.string().optional(),\n  dailyCap: z.number().int().positive().optional(),\n  throttleSeconds: z.number().int().positive().optional(),\n});"},"result":{"success":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/settings/mailboxes/new.tsx","linesAdded":3,"linesRemoved":3,"diffString":"--- a//Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/settings/mailboxes/new.tsx\n+++ b//Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/settings/mailboxes/new.tsx\n@@ -26,12 +26,12 @@\n   address: z.string().email(),\n   fromName: z.string().optional(),\n   host: z.string().min(1),\n-  port: z.coerce.number().int().positive(),\n+  port: z.number().int().positive(),\n   secure: z.boolean().optional(),\n   authUser: z.string().optional(),\n   authPass: z.string().optional(),\n-  dailyCap: z.coerce.number().int().positive().optional(),\n-  throttleSeconds: z.coerce.number().int().positive().optional(),\n+  dailyCap: z.number().int().positive().optional(),\n+  throttleSeconds: z.number().int().positive().optional(),\n });\n \n type FormValues = z.infer<typeof formSchema>;","beforeFullFileContent":"import { zodResolver } from \"@hookform/resolvers/zod\";\nimport { createFileRoute, Link, useNavigate } from \"@tanstack/react-router\";\nimport { Loader2 } from \"lucide-react\";\nimport { useForm } from \"react-hook-form\";\nimport { toast } from \"sonner\";\nimport { z } from \"zod\";\nimport { Button, buttonVariants } from \"@/components/ui/button\";\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport {\n  Form,\n  FormControl,\n  FormDescription,\n  FormField,\n  FormItem,\n  FormLabel,\n  FormMessage,\n} from \"@/components/ui/form\";\nimport { Input } from \"@/components/ui/input\";\nimport { createSmtpMailbox } from \"@/lib/mailboxes.functions\";\n\nexport const Route = createFileRoute(\"/_protected/settings/mailboxes/new\")({\n  component: NewMailboxPage,\n});\n\nconst formSchema = z.object({\n  address: z.string().email(),\n  fromName: z.string().optional(),\n  host: z.string().min(1),\n  port: z.coerce.number().int().positive(),\n  secure: z.boolean().optional(),\n  authUser: z.string().optional(),\n  authPass: z.string().optional(),\n  dailyCap: z.coerce.number().int().positive().optional(),\n  throttleSeconds: z.coerce.number().int().positive().optional(),\n});\n\ntype FormValues = z.infer<typeof formSchema>;\n\nfunction NewMailboxPage() {\n  const navigate = useNavigate();\n  const form = useForm<FormValues>({\n    resolver: zodResolver(formSchema),\n    defaultValues: {\n      address: \"sender@localhost\",\n      host: \"localhost\",\n      port: 1025,\n      secure: false,\n      dailyCap: 50,\n      throttleSeconds: 90,\n    },\n  });\n\n  const onSubmit = form.handleSubmit(async (values) => {\n    try {\n      await createSmtpMailbox({\n        data: {\n          address: values.address,\n          fromName: values.fromName,\n          host: values.host,\n          port: values.port,\n          secure: values.secure,\n          auth:\n            values.authUser && values.authPass\n              ? { user: values.authUser, pass: values.authPass }\n              : undefined,\n          dailyCap: values.dailyCap,\n          throttleSeconds: values.throttleSeconds,\n        },\n      });\n      toast.success(\"SMTP mailbox connected\");\n      void navigate({ to: \"/settings/mailboxes\" });\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Failed to create mailbox\");\n    }\n  });\n\n  return (\n    <div className=\"mx-auto max-w-xl space-y-6\">\n      <div>\n        <h1 className=\"text-2xl font-semibold\">Add mailbox</h1>\n        <p className=\"text-sm text-muted-foreground\">\n          Wave 1 supports SMTP (Mailpit locally). Gmail and Microsoft arrive in Wave 2.\n        </p>\n      </div>\n\n      <div className=\"flex gap-2\">\n        <Button type=\"button\" variant=\"default\">\n          SMTP\n        </Button>\n        <Button type=\"button\" variant=\"outline\" disabled title=\"Coming in Wave 2\">\n          Gmail\n        </Button>\n        <Button type=\"button\" variant=\"outline\" disabled title=\"Coming in Wave 2\">\n          Microsoft\n        </Button>\n      </div>\n\n      <Card>\n        <CardHeader>\n          <CardTitle>SMTP settings</CardTitle>\n          <CardDescription>\n            For local dev, use host <code className=\"text-xs\">localhost</code> and port{\" \"}\n            <code className=\"text-xs\">1025</code> (Mailpit).\n          </CardDescription>\n        </CardHeader>\n        <CardContent>\n          <Form {...form}>\n            <form onSubmit={onSubmit} className=\"space-y-4\">\n              <FormField\n                control={form.control}\n                name=\"address\"\n                render={({ field }) => (\n                  <FormItem>\n                    <FormLabel>From address</FormLabel>\n                    <FormControl>\n                      <Input {...field} type=\"email\" />\n                    </FormControl>\n                    <FormMessage />\n                  </FormItem>\n                )}\n              />\n              <FormField\n                control={form.control}\n                name=\"fromName\"\n                render={({ field }) => (\n                  <FormItem>\n                    <FormLabel>From name</FormLabel>\n                    <FormControl>\n                      <Input {...field} />\n                    </FormControl>\n                    <FormMessage />\n                  </FormItem>\n                )}\n              />\n              <div className=\"grid grid-cols-2 gap-4\">\n                <FormField\n                  control={form.control}\n                  name=\"host\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>SMTP host</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"port\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Port</FormLabel>\n                      <FormControl>\n                        <Input {...field} type=\"number\" />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n              </div>\n              <div className=\"grid grid-cols-2 gap-4\">\n                <FormField\n                  control={form.control}\n                  name=\"authUser\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Username (optional)</FormLabel>\n                      <FormControl>\n                        <Input {...field} autoComplete=\"off\" />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"authPass\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Password (optional)</FormLabel>\n                      <FormControl>\n                        <Input {...field} type=\"password\" autoComplete=\"new-password\" />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n              </div>\n              <div className=\"grid grid-cols-2 gap-4\">\n                <FormField\n                  control={form.control}\n                  name=\"dailyCap\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Daily cap</FormLabel>\n                      <FormControl>\n                        <Input {...field} type=\"number\" />\n                      </FormControl>\n                      <FormDescription>Max sends per day (enforced in Phase 6).</FormDescription>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"throttleSeconds\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Throttle (seconds)</FormLabel>\n                      <FormControl>\n                        <Input {...field} type=\"number\" />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n              </div>\n              <div className=\"flex gap-2 pt-2\">\n                <Button type=\"submit\" disabled={form.formState.isSubmitting}>\n                  {form.formState.isSubmitting ? (\n                    <Loader2 className=\"h-4 w-4 animate-spin\" />\n                  ) : (\n                    \"Connect mailbox\"\n                  )}\n                </Button>\n                <Button type=\"button\" variant=\"outline\" asChild={false}>