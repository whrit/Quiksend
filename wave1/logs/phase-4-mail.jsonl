 connected\");\n      void navigate({ to: \"/settings/mailboxes\" });\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Failed to create mailbox\");\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  return (\n    <div className=\"mx-auto max-w-xl space-y-6\">\n      <div>\n        <h1 className=\"text-2xl font-semibold\">Add mailbox</h1>\n        <p className=\"text-sm text-muted-foreground\">\n          Wave 1 supports SMTP (Mailpit locally). Gmail and Microsoft arrive in Wave 2.\n        </p>\n      </div>\n\n      <div className=\"flex gap-2\">\n        <Button type=\"button\" variant=\"default\">\n          SMTP\n        </Button>\n        <Button type=\"button\" variant=\"outline\" disabled title=\"Coming in Wave 2\">\n          Gmail\n        </Button>\n        <Button type=\"button\" variant=\"outline\" disabled title=\"Coming in Wave 2\">\n          Microsoft\n        </Button>\n      </div>\n\n      <Card>\n        <CardHeader>\n          <CardTitle>SMTP settings</CardTitle>\n          <CardDescription>\n            For local dev, use host <code className=\"text-xs\">localhost</code> and port{\" \"}\n            <code className=\"text-xs\">1025</code> (Mailpit).\n          </CardDescription>\n        </CardHeader>\n        <CardContent>\n          <form onSubmit={(e) => void onSubmit(e)} className=\"space-y-4\">\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"address\">From address</Label>\n              <Input\n                id=\"address\"\n                type=\"email\"\n                required\n                value={address}\n                onChange={(e) => setAddress(e.target.value)}\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"fromName\">From name</Label>\n              <Input id=\"fromName\" value={fromName} onChange={(e) => setFromName(e.target.value)} />\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"host\">SMTP host</Label>\n                <Input id=\"host\" required value={host} onChange={(e) => setHost(e.target.value)} />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"port\">Port</Label>\n                <Input\n                  id=\"port\"\n                  type=\"number\"\n                  required\n                  value={port}\n                  onChange={(e) => setPort(e.target.value)}\n                />\n              </div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"authUser\">Username (optional)</Label>\n                <Input\n                  id=\"authUser\"\n                  autoComplete=\"off\"\n                  value={authUser}\n                  onChange={(e) => setAuthUser(e.target.value)}\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"authPass\">Password (optional)</Label>\n                <Input\n                  id=\"authPass\"\n                  type=\"password\"\n                  autoComplete=\"new-password\"\n                  value={authPass}\n                  onChange={(e) => setAuthPass(e.target.value)}\n                />\n              </div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"dailyCap\">Daily cap</Label>\n                <Input\n                  id=\"dailyCap\"\n                  type=\"number\"\n                  value={dailyCap}\n                  onChange={(e) => setDailyCap(e.target.value)}\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"throttle\">Throttle (seconds)</Label>\n                <Input\n                  id=\"throttle\"\n                  type=\"number\"\n                  value={throttleSeconds}\n                  onChange={(e) => setThrottleSeconds(e.target.value)}\n                />\n              </div>\n            </div>\n            <div className=\"flex gap-2 pt-2\">\n              <Button type=\"submit\" disabled={submitting}>\n                {submitting ? <Loader2 className=\"h-4 w-4 animate-spin\" /> : \"Connect mailbox\"}\n              </Button>\n              <Link to=\"/settings/mailboxes\" className={buttonVariants({ variant: \"outline\" })}>\n                Cancel\n              </Link>\n            </div>\n          </form>\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n"},"result":{"success":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/settings/mailboxes/new.tsx","linesAdded":96,"linesRemoved":168,"diffString":"--- a//Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/settings/mailboxes/new.tsx\n+++ b//Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/settings/mailboxes/new.tsx\n@@ -1,78 +1,52 @@\n-import { zodResolver } from \"@hookform/resolvers/zod\";\n import { createFileRoute, Link, useNavigate } from \"@tanstack/react-router\";\n import { Loader2 } from \"lucide-react\";\n-import { useForm } from \"react-hook-form\";\n+import { useState } from \"react\";\n import { toast } from \"sonner\";\n-import { z } from \"zod\";\n import { Button, buttonVariants } from \"@/components/ui/button\";\n import { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\n-import {\n-  Form,\n-  FormControl,\n-  FormDescription,\n-  FormField,\n-  FormItem,\n-  FormLabel,\n-  FormMessage,\n-} from \"@/components/ui/form\";\n import { Input } from \"@/components/ui/input\";\n+import { Label } from \"@/components/ui/label\";\n import { createSmtpMailbox } from \"@/lib/ma