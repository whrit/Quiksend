{"type":"tool_call","subtype":"started","call_id":"tool_94208520-ec2d-4ada-940d-d885ae3dd91","tool_call":{"editToolCall":{"args":{"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/scripts/phase4-mailpit-smoke.ts","streamContent":"/**\n * Phase 4 Mailpit smoke — sends via SMTP adapter and verifies MIME headers.\n * Run: dotenv -e .env -- tsx scripts/phase4-mailpit-smoke.ts\n */\nimport { createSmtpTransport, sendMime } from \"@quiksend/mail\";\nimport { buildMime } from \"@quiksend/mail/mime\";\nimport { normalizeMessageId } from \"@quiksend/mail/threading\";\n\nconst compliance = {\n  unsubscribeUrl: \"https://app.example.com/u/pending\",\n  senderPostalAddress: \"1 Main St, City\",\n  senderOrgName: \"Quiksend Smoke\",\n};\n\nconst mime = buildMime({\n  from: { email: \"smoke@localhost\", name: \"Quiksend Smoke\" },\n  to: [{ email: \"recipient@example.com\" }],\n  subject: \"Phase 4 smoke test\",\n  html: \"<p>SMTP → Mailpit smoke</p>\",\n  text: \"SMTP → Mailpit smoke\",\n  compliance,\n});\n\nconst transport = createSmtpTransport({\n  host: \"localhost\",\n  port: 1025,\n  fromAddress: \"smoke@localhost\",\n});\n\nconst result = await sendMime(transport, mime);\nconst normalized = normalizeMessageId(result.messageId);\n\nconsole.log(\"Send OK\");\nconsole.log(\"messageId:\", normalized);\nconsole.log(\"providerMessageId:\", result.providerMessageId);\nconsole.log(\"has List-Unsubscribe:\", mime.raw.includes(\"List-Unsubscribe:\"));\nconsole.log(\"has physical address footer:\", mime.raw.includes(\"1 Main St, City\"));\n\nif (!mime.raw.includes(\"List-Unsubscribe:\")) process.exit(1);\nif (!normalized.startsWith(\"<\") || !normalized.endsWith(\">\")) process.exit(1);\n"}},"hookAdditionalContexts":[],"toolCallId":"tool_94208520-ec2d-4ada-940d-d885ae3dd91","startedAtMs":"1782958146101"},"model_call_id":"7e5022f7-c767-4b04-a8e4-816de5d91a39-57-zdm6","session_id":"96149331-134f-48b3-9ea0-fe7607af1532","timestamp_ms":1782958146136}
