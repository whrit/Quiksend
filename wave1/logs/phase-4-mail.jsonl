oxes.functions\";\n\nexport const Route = createFileRoute(\"/_protected/settings/mailboxes/new\")({\n  component: NewMailboxPage,\n});\n\nconst formSchema = z.object({\n  address: z.string().email(),\n  fromName: z.string().optional(),\n  host: z.string().min(1),\n  port: z.coerce.number().int().positive(),\n  secure: z.boolean().optional(),\n  authUser: z.string().optional(),\n  authPass: z.string().optional(),\n  dailyCap: z.coerce.number().int().positive().optional(),\n  throttleSeconds: z.coerce.number().int().positive().optional(),\n});\n\ntype FormValues = z.infer<typeof formSchema>;\n\nfunction NewMailboxPage() {\n  const navigate = useNavigate();\n  const form = useForm<FormValues>({\n    resolver: zodResolver(formSchema),\n    defaultValues: {\n      address: \"sender@localhost\",\n      host: \"localhost\",\n      port: 1025,\n      secure: false,\n      dailyCap: 50,\n      throttleSeconds: 90,\n    },\n  });\n\n  const onSubmit = form.handleSubmit(async (values) => {\n    try {\n      await createSmtpMailbox({\n        data: {\n          address: values.address,\n          fromName: values.fromName,\n          host: values.host,\n          port: values.port,\n          secure: values.secure,\n          auth:\n            values.authUser && values.authPass\n              ? { user: values.authUser, pass: values.authPass }\n              : undefined,\n          dailyCap: values.dailyCap,\n          throttleSeconds: values.throttleSeconds,\n        },\n      });\n      toast.success(\"SMTP mailbox connected\");\n      void navigate({ to: \"/settings/mailboxes\" });\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Failed to create mailbox\");\n    }\n  });\n\n  return (\n    <div className=\"mx-auto max-w-xl space-y-6\">\n      <div>\n        <h1 className=\"text-2xl font-semibold\">Add mailbox</h1>\n        <p className=\"text-sm text-muted-foreground\">\n          Wave 1 supports SMTP (Mailpit locally). Gmail and Microsoft arrive in Wave 2.\n        </p>\n      </div>\n\n      <div className=\"flex gap-2\">\n        <Button type=\"button\" variant=\"default\">\n          SMTP\n        </Button>\n        <Button type=\"button\" variant=\"outline\" disabled title=\"Coming in Wave 2\">\n          Gmail\n        </Button>\n        <Button type=\"button\" variant=\"outline\" disabled title=\"Coming in Wave 2\">\n          Microsoft\n        </Button>\n      </div>\n\n      <Card>\n        <CardHeader>\n          <CardTitle>SMTP settings</CardTitle>\n          <CardDescription>\n            For local dev, use host <code className=\"text-xs\">localhost</code> and port{\" \"}\n            <code className=\"text-xs\">1025</code> (Mailpit).\n          </CardDescription>\n        </CardHeader>\n        <CardContent>\n          <Form {...form}>\n            <form onSubmit={onSubmit} className=\"space-y-4\">\n              <FormField\n                control={form.control}\n                name=\"address\"\n                render={({ field }) => (\n                  <FormItem>\n                    <FormLabel>From address</FormLabel>\n                    <FormControl>\n                      <Input {...field} type=\"email\" />\n                    </FormControl>\n                    <FormMessage />\n                  </FormItem>\n                )}\n              />\n              <FormField\n                control={form.control}\n                name=\"fromName\"\n                render={({ field }) => (\n                  <FormItem>\n                    <FormLabel>From name</FormLabel>\n                    <FormControl>\n                      <Input {...field} />\n                    </FormControl>\n                    <FormMessage />\n                  </FormItem>\n                )}\n              />\n              <div className=\"grid grid-cols-2 gap-4\">\n                <FormField\n                  control={form.control}\n                  name=\"host\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>SMTP host</FormLabel>\n                      <FormControl>\n                        <Input {...field} />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"port\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Port</FormLabel>\n                      <FormControl>\n                        <Input {...field} type=\"number\" />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n              </div>\n              <div className=\"grid grid-cols-2 gap-4\">\n                <FormField\n                  control={form.control}\n                  name=\"authUser\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Username (optional)</FormLabel>\n                      <FormControl>\n                        <Input {...field} autoComplete=\"off\" />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"authPass\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Password (optional)</FormLabel>\n                      <FormControl>\n                        <Input {...field} type=\"password\" autoComplete=\"new-password\" />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n              </div>\n              <div className=\"grid grid-cols-2 gap-4\">\n                <FormField\n                  control={form.control}\n                  name=\"dailyCap\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Daily cap</FormLabel>\n                      <FormControl>\n                        <Input {...field} type=\"number\" />\n                      </FormControl>\n                      <FormDescription>Max sends per day (enforced in Phase 6).</FormDescription>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n                <FormField\n                  control={form.control}\n                  name=\"throttleSeconds\"\n                  render={({ field }) => (\n                    <FormItem>\n                      <FormLabel>Throttle (seconds)</FormLabel>\n                      <FormControl>\n                        <Input {...field} type=\"number\" />\n                      </FormControl>\n                      <FormMessage />\n                    </FormItem>\n                  )}\n                />\n              </div>\n              <div className=\"flex gap-2 pt-2\">\n                <Button type=\"submit\" disabled={form.formState.isSubmitting}>\n                  {form.formState.isSubmitting ? (\n                    <Loader2 className=\"h-4 w-4 animate-spin\" />\n                  ) : (\n                    \"Connect mailbox\"\n                  )}\n                </Button>\n                <Link to=\"/settings/mailboxes\" className={buttonVariants({ variant: \"outline\" })}>\n                  Cancel\n                </Link>\n              </div>\n            </form>\n          </Form>\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n","afterFullFileContent":"import { createFileRoute, Link, useNavigate } from \"@tanstack/react-router\";\nimport { Loader2 } from \"lucide-react\";\nimport { useState } from \"react\";\nimport { toast } from \"sonner\";\nimport { Button, buttonVariants } from \"@/components/ui/button\";\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\nimport { createSmtpMailbox } from \"@/lib/mailboxes.functions\";\n\nexport const Route = createFileRoute(\"/_protected/settings/mailboxes/new\")({\n  component: NewMailboxPage,\n});\n\nfunction NewMailboxPage() {\n  const navigate = useNavigate();\n  const [address, setAddress] = useState(\"sender@localhost\");\n  const [fromName, setFromName] = useState(\"\");\n  const [host, setHost] = useState(\"localhost\");\n  const [port, setPort] = useState(\"1025\");\n  const [authUser, setAuthUser] = useState(\"\");\n  const [authPass, setAuthPass] = useState(\"\");\n  const [dailyCap, setDailyCap] = useState(\"50\");\n  const [throttleSeconds, setThrottleSeconds] = useState(\"90\");\n  const [submitting, setSubmitting] = useState(false);\n\n  const onSubmit = async (event: React.FormEvent) => {\n    event.preventDefault();\n    setSubmitting(true);\n    try {\n      await createSmtpMailbox({\n        data: {\n          address,\n          fromName: fromName || undefined,\n          host,\n          port: Number(port),\n          auth: authUser && authPass ? { user: authUser, pass: authPass } : undefined,\n          dailyCap: Number(dailyCap),\n          throttleSeconds: Number(throttleSeconds),\n        },\n      });\n      toast.success(\"SMTP mailbox connected\");\n      void navigate({ to: \"/settings/mailboxes\" });\n    } catch (err) {\n      toast.error(err instanceof Error ? err.message : \"Failed to create mailbox\");\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  return (\n    <div className=\"mx-auto max-w-xl space-y-6\">\n      <div>\n        <h1 className=\"text-2xl font-semibold\">Add mailbox</h1>\n        <p className=\"text-sm text-muted-foreground\">\n          Wave 1 supports SMTP (Mailpit locally). Gmail and Microsoft arrive in Wave 2.\n        </p>\n      </div>\n\n      <div className=\"flex gap-2\">\n        <Button type=\"button\" variant=\"default\">\n          SMTP\n        </Button>\n        <Button type=\"button\" variant=\"outline\" disabled title=\"Coming in Wave 2\">\n          Gmail\n        </Button>\n        <Button type=\"button\" variant=\"outline\" disabled title=\"Coming in Wave 2\">\n          Microsoft\n        </Button>\n      </div>\n\n      <Card>\n        <CardHeader>\n          <CardTitle>SMTP settings</CardTitle>\n          <CardDescription>\n            For local dev, use host <code className=\"text-xs\">localhost</code> and port{\" \"}\n            <code className=\"text-xs\">1025</code> (Mailpit).\n          </CardDescription>\n        </CardHeader>\n        <CardContent>\n          <form onSubmit={(e) => void onSubmit(e)} className=\"space-y-4\">\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"address\">From address</Label>\n              <Input\n                id=\"address\"\n                type=\"email\"\n                required\n                value={address}\n                onChange={(e) => setAddress(e.target.value)}\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"fromName\">From name</Label>\n              <Input id=\"fromName\" value={fromName} onChange={(e) => setFromName(e.target.value)} />\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"host\">SMTP host</Label>\n                <Input id=\"host\" required value={host} onChange={(e) => setHost(e.target.value)} />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"port\">Port</Label>\n                <Input\n                  id=\"port\"\n                  type=\"number\"\n                  required\n                  value={port}\n                  onChange={(e) => setPort(e.target.value)}\n                />\n              </div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"authUser\">Username (optional)</Label>\n                <Input\n                  id=\"authUser\"\n                  autoComplete=\"off\"\n                  value={authUser}\n                  onChange={(e) => setAuthUser(e.target.value)}\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"authPass\">Password (optional)</Label>\n                <Input\n                  id=\"authPass\"\n                  type=\"password\"\n                  autoComplete=\"new-password\"\n                  value={authPass}\n                  onChange={(e) => setAuthPass(e.target.value)}\n                />\n              </div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"dailyCap\">Daily cap</Label>\n                <Input\n                  id=\"dailyCap\"\n                  type=\"number\"\n                  value={dailyCap}\n                  onChange={(e) => setDailyCap(e.target.value)}\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"throttle\">Throttle (seconds)</Label>\n                <Input\n                  id=\"throttle\"\n                  type=\"number\"\n                  value={throttleSeconds}\n                  onChange={(e) => setThrottleSeconds(e.target.value)}\n                />\n              </div>\n            </div>\n            <div className=\"flex gap-2 pt-2\">\n              <Button type=\"submit\" disabled={submitting}>\n                {submitting ? <Loader2 className=\"h-4 w-4 animate-spin\" /> : \"Connect mailbox\"}\n              </Button>\n              <Link to=\"/settings/mailboxes\" className={buttonVariants({ variant: \"outline\" })}>\n                Cancel\n              </Link>\n            </div>\n          </form>\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n","message":"Wrote contents to /Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/apps/web/src/routes/_protected/settings/mailboxes/new.tsx"}}},"hookAdditionalContexts":[],"toolCallId":"tool_2c6381c5-2b9c-4343-8204-ed8d23bc77c","startedAtMs":"1782958069498","completedAtMs":"1782958074099"},"model_call_id":"7e5022f7-c767-4b04-a8e4-816de5d91a39-54-t8cc","session_id":"96149331-134f-48b3-9ea0-fe7607af1532","timestamp_ms":1782958074150}
