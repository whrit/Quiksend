    return state.identity;\n    },\n  };\n\n  return { adapter, state };\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":62,"fileSize":1746,"path":"/Users/beckett/.cursor/worktrees/quiksend/phase-4-mail/packages/mail/src/adapters/fake.ts","readRange":{"startLine":1,"endLine":62},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}},"hookAdditionalContexts":[],"toolCallId":"tool_ba09dc1c-f5bc-4f47-80fc-79e0c7fcca0","startedAtMs":"1782957244254","completedAtMs":"1782957247006"},"model_call_id":"7e5022f7-c767-4b04-a8e4-816de5d91a39-4-w07e","session_id":"96149331-134f-48b3-9ea0-fe7607af1532","timestamp_ms":1782957246974}
